#!/usr/bin/env bash

# build — local CI equivalent for rotate-aws-backups.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# SYNOPSIS
#   build [--push] [--version VERSION] [--platform PLATFORMS]
#         [--registry REGISTRY] [--no-sbom] [--no-provenance]
#         [--no-lint] [--no-test] [--no-smoke] [--no-coverage] [--no-scan]
#         [--advise [ADVISEMENTS]] [--advice [ADVISEMENTS]] [--no-advise]
#         [--cache CACHE_RULES]
#         [--dry-run] [--help]
#
# OPTIONS
#   --push              Push the image to the registry after a successful build.
#                       Omitting this flag builds locally only (the default).
#   --version VERSION   Tag the image with this version string, e.g. "1.2.3".
#                       When omitted the image is tagged "dev-<git-short-sha>"
#                       so that local builds are never confused with released
#                       artifacts.
#   --platform PLATFORMS
#                       Comma-separated list of target platforms for --push.
#                       Default: linux/amd64,linux/arm64
#   --registry REGISTRY Docker Hub username / registry prefix.
#                       Default: 1121citrus
#   --no-sbom           Skip generating an SBOM attestation (push only).
#   --no-provenance     Skip generating a provenance attestation (push only).
#   --no-lint           Skip hadolint Dockerfile check.
#   --no-test           Skip running the bats test suite.
#   --no-smoke          Skip the built-image smoke test stage.
#   --no-coverage       Skip the kcov bash coverage report (advisory only).
#   --no-scan           Skip the Trivy vulnerability scan (gating).
#                       Also skips advisements (stage 5) by default; pass --advise
#                       after --no-scan to keep the advisory scans.
#   --advise [ADVISEMENTS]
#                       Run advisory scans. Comma-delimited list:
#                       'grype', 'scout', 'dive', 'all', 'none', or any
#                       combination, e.g. 'grype,dive'. 'all' selects
#                       every available advisement. 'none' disables all
#                       (equivalent to --no-advise). Default with no list
#                       given: 'grype,scout'. Advisory scans are off by
#                       default.
#   --advice [ADVISEMENTS]
#                       Synonym for --advise.
#   --no-advise         Disable all advisory scans (equivalent to
#                       --advise none).
#   --cache CACHE_RULES One-run cache controls for scanner DBs.
#                       Rule format: 'reset=<targets>;skip-update=<targets>'
#                       Targets: trivy, grype, all (comma-delimited)
#                       Examples:
#                         --cache 'reset=all'
#                         --cache 'skip-update=grype'
#                         --cache 'reset=grype;skip-update=trivy'
#   --dry-run           Print each command without executing it.
#   --help              Print this message and exit.
#
# ENVIRONMENT
#   The following env-var overrides take precedence over the defaults above but
#   are themselves overridden by the matching CLI flag:
#     BUILD_VERSION, BUILD_PUSH, BUILD_PLATFORM, BUILD_REGISTRY
#     BUILD_LINT, BUILD_TEST, BUILD_SMOKE, BUILD_COVERAGE, BUILD_SCAN,
#     BUILD_ADVISE
#   ROTATE_BACKUPS_VERSION
#     Optional: pin the rotate-backups Python package version passed as a
#     build-arg, e.g. ROTATE_BACKUPS_VERSION=7.1 ./build
#
# PREREQUISITES
#   • docker with the buildx plugin (≥ 0.10)
#   • For --push: docker login <registry> must already be authenticated, plus
#     QEMU binfmt helpers for cross-platform builds:
#       docker run --rm --privileged tonistiigi/binfmt --install all
#
# STAGES (run in order; each can be skipped with --no-<stage>)
#   1. Lint   — hadolint (Dockerfile)
#   2. Build  — single-platform --load into local Docker daemon
#   3. Test   — bats test suite (runs in bats/bats:1.13.0 Docker container)
#   3b. Smoke    — image-level sanity check against the built image (blocking)
#   3c. Coverage — kcov bash line coverage report (advisory; never blocks)
#   4. Scan   — Trivy CRITICAL/HIGH image scan (blocking; exit 1 on findings)
#   5. Advise — multiple advisory scans (advisory only; never blocks the build)
#              a) Grype   — full-severity scan
#              b) Scout   — Docker Scout CVE scan
#              c) Dive    — image layer analysis
#   6. Push   — multi-platform rebuild + push to registry (only with --push)
#
# EXAMPLES
#   # Local dev cycle — lint, build, test, scan, advise
#   ./build
#
#   # Release build — push version 1.2.3 and latest
#   ./build --push --version 1.2.3
#
#   # Run only Grype advisory (skip Docker Scout)
#   ./build --advise grype
#
#   # Run only Docker Scout (skip Grype)
#   ./build --advise scout
#
#   # Run all three advisements: Grype, Scout, and Dive
#   ./build --advise grype,scout,dive
#
#   # Compatibility alias
#   ./build --advice all
#
#   # Run Dive analysis only
#   ./build --advise dive
#
#   # Reset scanner DB caches for this run, then skip Grype DB update once
#   ./build --cache 'reset=all;skip-update=grype'
#
#   # Pin the rotate-backups version
#   ROTATE_BACKUPS_VERSION=7.1 ./build
#
#   # Dry-run: just print each command
#   ./build --dry-run
#
# HELP_ENDS_HERE

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults — may be overridden by environment variables or CLI flags.
# ---------------------------------------------------------------------------
PUSH=${BUILD_PUSH:-false}
VERSION=${BUILD_VERSION:-}
PLATFORMS=${BUILD_PLATFORM:-linux/amd64,linux/arm64}
REGISTRY=${BUILD_REGISTRY:-1121citrus}
SBOM=true
PROVENANCE=true
LINT=${BUILD_LINT:-true}
TEST=${BUILD_TEST:-true}
SMOKE=${BUILD_SMOKE:-true}
COVERAGE=${BUILD_COVERAGE:-true}
SCAN=${BUILD_SCAN:-true}
ADVISE_GRYPE=false
ADVISE_SCOUT=false
ADVISE_DIVE=false
_ADVISE_EXPLICIT=false   # set true when --advise or --no-advise is passed
CACHE_RESET_TRIVY=false
CACHE_RESET_GRYPE=false
CACHE_SKIP_UPDATE_TRIVY=false
CACHE_SKIP_UPDATE_GRYPE=false
DRY_RUN=false

IMAGE_NAME=rotate-aws-backups

# Tool image references — update these to pin analyser versions project-wide.
HADOLINT_IMAGE=hadolint/hadolint
HADOLINT_TAG=v2.12.0
MARKDOWNLINT_IMAGE=ghcr.io/igorshubovych/markdownlint-cli
MARKDOWNLINT_TAG=v0.48.0
SHELLCHECK_IMAGE=koalaman/shellcheck
SHELLCHECK_TAG=v0.10.0
TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.62.1
GRYPE_IMAGE=anchore/grype
GRYPE_TAG=v0.87.0
DIVE_IMAGE=wagoodman/dive
DIVE_TAG=v0.13.1
DIVE_DOCKER_CLIENT_API=1.47
BATS_KCOV_IMAGE=1121citrus/bats-kcov
BATS_KCOV_TAG=latest

TRIVY_CACHE_VOLUME=rotate-aws-backups-trivy-cache
GRYPE_CACHE_VOLUME=rotate-aws-backups-grype-cache
GRYPE_DB_CACHE_DIR=/grype-db

# ---------------------------------------------------------------------------
# Helpers: cache control parsing
# ---------------------------------------------------------------------------
set_cache_targets() {
    local mode="$1"
    local targets_csv="$2"
    local target
    IFS=',' read -ra _cache_targets <<< "${targets_csv}"

    for target in "${_cache_targets[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]]; then
                    CACHE_RESET_TRIVY=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    CACHE_SKIP_UPDATE_TRIVY=true
                fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]]; then
                    CACHE_RESET_GRYPE=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    CACHE_RESET_TRIVY=true
                    CACHE_RESET_GRYPE=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    CACHE_SKIP_UPDATE_TRIVY=true
                    CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *)
                echo "Unknown cache target: ${target}" >&2
                exit 1
                ;;
        esac
    done
}

parse_cache_rules() {
    local rules="$1"
    local entry
    local key
    local value
    IFS=';' read -ra _cache_rules <<< "${rules}"

    for entry in "${_cache_rules[@]}"; do
        key="${entry%%=*}"
        value="${entry#*=}"
        key="${key//[[:space:]]/}"
        value="${value//[[:space:]]/}"
        key="${key,,}"
        value="${value,,}"

        if [[ -z "${key}" && -z "${value}" ]]; then
            continue
        fi

        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2
            exit 1
        fi

        case "${key}" in
            reset|skip-update)
                set_cache_targets "${key}" "${value}"
                ;;
            *)
                echo "Unknown --cache rule key: ${key}" >&2
                exit 1
                ;;
        esac
    done
}

volume_has_file() {
    local volume_name="$1"
    local file_path="$2"

    if [[ "${DRY_RUN}" == "true" ]]; then
        return 1
    fi

    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.20 \
        sh -c "test -f \"${file_path}\""
}

volume_has_entries() {
    local volume_name="$1"
    local dir_path="$2"

    if [[ "${DRY_RUN}" == "true" ]]; then
        return 1
    fi

    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.20 \
        sh -c "ls -A \"${dir_path}\" >/dev/null 2>&1"
}

grype_db_ready() {
    local volume_name="$1"

    if [[ "${DRY_RUN}" == "true" ]]; then
        return 1
    fi

    docker run --rm \
        -e "GRYPE_DB_CACHE_DIR=${GRYPE_DB_CACHE_DIR}" \
        -v "${volume_name}:${GRYPE_DB_CACHE_DIR}" \
        "${GRYPE_IMAGE}:${GRYPE_TAG}" db status >/dev/null 2>&1
}

reset_cache_db() {
    local volume_name="$1"
    # Reset the volume by removing all contents and recreating the directory structure
    run docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.21 \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --push)             PUSH=true ;;
        --version)          VERSION="$2"; shift ;;
        --platform)         PLATFORMS="$2"; shift ;;
        --registry)         REGISTRY="$2"; shift ;;
        --no-sbom)          SBOM=false ;;
        --no-provenance)    PROVENANCE=false ;;
        --no-lint)          LINT=false ;;
        --no-test)          TEST=false ;;
        --no-smoke)         SMOKE=false ;;
        --no-coverage)      COVERAGE=false ;;
        --no-scan)          SCAN=false ;;
        --advise|--advice)
            _ADVISE_EXPLICIT=true
            # Check if next arg looks like an advisement list (no -- prefix)
            if [[ $# -gt 1 && ! "$2" =~ ^-- ]]; then
                advisements="$2"; shift
            else
                advisements="grype,scout"
            fi
            # Parse the comma-delimited list
            ADVISE_GRYPE=false
            ADVISE_SCOUT=false
            ADVISE_DIVE=false
            IFS=',' read -ra adv_list <<< "$advisements"
            for adv in "${adv_list[@]}"; do
                adv="${adv//[[:space:]]/}"
                adv="${adv,,}"
                case "$adv" in
                    grype)  ADVISE_GRYPE=true ;;
                    scout)  ADVISE_SCOUT=true ;;
                    dive)   ADVISE_DIVE=true ;;
                    all)    ADVISE_GRYPE=true; ADVISE_SCOUT=true; ADVISE_DIVE=true ;;
                    none)   ADVISE_GRYPE=false; ADVISE_SCOUT=false; ADVISE_DIVE=false ;;
                    *)      echo "Unknown advisement: $adv" >&2; exit 1 ;;
                esac
            done
            ;;
        --no-advise)
            ADVISE_GRYPE=false
            ADVISE_SCOUT=false
            ADVISE_DIVE=false
            _ADVISE_EXPLICIT=true
            ;;
        --cache)
            if [[ $# -lt 2 || "$2" =~ ^-- ]]; then
                echo "--cache requires CACHE_RULES" >&2
                exit 1
            fi
            parse_cache_rules "$2"
            shift
            ;;
        --dry-run)          DRY_RUN=true ;;
        --help|-h)
            sed -n '3,/^# HELP_ENDS_HERE/p' "$0" | grep '^#' | sed 's/^# \{0,1\}//' | head -n -1
            exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1 ;;
    esac
    shift
done

# --no-scan implies --no-advise unless --advise was given explicitly.
if [[ "${SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
    ADVISE_GRYPE=false
    ADVISE_SCOUT=false
    ADVISE_DIVE=false
fi

# ---------------------------------------------------------------------------
# Resolve the image version tag.
# ---------------------------------------------------------------------------
if [[ -z "${VERSION}" ]]; then
    sha=$(git -C "$(dirname "$0")" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    VERSION="dev-${sha}"
fi

# ---------------------------------------------------------------------------
# Construct the tag list.
# "latest" is only added for non-dev (release) builds that will be pushed.
# ---------------------------------------------------------------------------
full_image="${REGISTRY}/${IMAGE_NAME}"
tags=("--tag" "${full_image}:${VERSION}")
if [[ "${PUSH}" == "true" && "${VERSION}" != dev-* ]]; then
    tags+=("--tag" "${full_image}:latest")
fi

# Optional build-arg to pin the rotate-backups Python package version.
rotate_build_arg=()
if [[ -n "${ROTATE_BACKUPS_VERSION:-}" ]]; then
    rotate_build_arg=("--build-arg" "ROTATE_BACKUPS_VERSION=${ROTATE_BACKUPS_VERSION}")
fi

# Build-arg for the application version (stored in the image as a version file).
version_build_arg=("--build-arg" "VERSION=${VERSION}")

# ---------------------------------------------------------------------------
# Helper: execute a command or print it for --dry-run.
# ---------------------------------------------------------------------------
run() {
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN]" "$@" >&2
    else
        "$@"
    fi
}

# Run a command with a timeout (no external 'timeout' binary required).
# Backgrounds the command, starts a watchdog that kills it after SECONDS,
# then waits.  In --dry-run mode just prints the command.
# Usage: _timed SECONDS COMMAND [ARGS...]
_timed() {
    local secs="$1"; shift
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] (${secs}s timeout)" "$@" >&2
        return 0
    fi
    "$@" &
    local _pid=$!
    ( sleep "${secs}" && kill "${_pid}" 2>/dev/null ) &
    local _watcher=$!
    wait "${_pid}" 2>/dev/null; local _rc=$?
    kill "${_watcher}" 2>/dev/null
    wait "${_watcher}" 2>/dev/null
    return "${_rc}"
}

if [[ "${CACHE_RESET_TRIVY}" == "true" ]]; then
    echo "==> Cache: reset Trivy DB" >&2
    reset_cache_db "${TRIVY_CACHE_VOLUME}"
fi

if [[ "${CACHE_RESET_GRYPE}" == "true" ]]; then
    echo "==> Cache: reset Grype DB" >&2
    reset_cache_db "${GRYPE_CACHE_VOLUME}"
fi

# Script directory for build context and relative paths.
script_dir=$(dirname "$(readlink -f "$0")")

echo "Image:     ${full_image}:${VERSION}" >&2
echo "Platforms: ${PLATFORMS}" >&2
echo "Push:      ${PUSH}" >&2
echo "Trivy DB:  volume:${TRIVY_CACHE_VOLUME}" >&2
echo "Grype DB:  volume:${GRYPE_CACHE_VOLUME}" >&2
echo "" >&2

# ---------------------------------------------------------------------------
# Stage 1: Lint
# ---------------------------------------------------------------------------
if [[ "${LINT}" == "true" ]]; then
    echo "==> Stage 1: Lint" >&2

    echo "    hadolint Dockerfile" >&2
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] docker run --rm -i hadolint/hadolint < Dockerfile" >&2
    else
        docker run --rm -i "${HADOLINT_IMAGE}:${HADOLINT_TAG}" < "${script_dir}/Dockerfile"
    fi

    echo "    shellcheck bash scripts" >&2
    run docker run --rm \
        -v "${script_dir}:/mnt:ro" \
        --workdir /mnt \
        "${SHELLCHECK_IMAGE}:${SHELLCHECK_TAG}" \
            build \
            src/healthcheck \
            src/include/common-functions \
            src/rotate \
            src/rotate-aws-backups \
            src/startup \
            test/bin/aws \
            test/bin/jq \
            test/bin/rotate-backups \
            test/staging \
            test/test_helper.bash

    echo "    markdownlint markdown files" >&2
    run docker run --rm \
        -v "${script_dir}:/md:ro" \
        --workdir /md \
        "${MARKDOWNLINT_IMAGE}:${MARKDOWNLINT_TAG}" \
            '**/*.md'
fi

# ---------------------------------------------------------------------------
# Stage 2: Build (local, single-platform)
# ---------------------------------------------------------------------------
echo "==> Stage 2: Build ${full_image}:${VERSION}" >&2

host_platform=$(docker info --format '{{.OSType}}/{{.Architecture}}' 2>/dev/null \
    || echo "linux/amd64")

build_cmd=(
    docker buildx build
    --platform "${host_platform}"
    "${tags[@]}"
    "${rotate_build_arg[@]}"
    "${version_build_arg[@]}"
    --load
)

if [[ -n "${BUILD_EXTRA_ARGS:-}" ]]; then
    # shellcheck disable=SC2206
    build_cmd+=(${BUILD_EXTRA_ARGS})
fi

build_cmd+=("${script_dir}")

if [[ "${DRY_RUN}" == "true" ]]; then
    echo "[DRY RUN] Would execute:" >&2
    printf '  %s \\\n' "${build_cmd[@]}"
else
    "${build_cmd[@]}"
fi

# ---------------------------------------------------------------------------
# Stage 3: Test (bats)
# ---------------------------------------------------------------------------
# Tests run inside the official bats/bats:1.13.0 container with the project
# source bind-mounted.  This avoids requiring bats to be installed on the host
# and keeps the test environment consistent with CI.
if [[ "${TEST}" == "true" ]]; then
    echo "==> Stage 3: Test" >&2
    run docker run -i --rm \
        -v "${script_dir}:/code:ro" \
        -w /code \
        bats/bats:1.13.0 \
            test/01-dockerfile.bats \
            test/02-functional.bats \
            test/03-build.bats \
            test/04-image-metadata.bats \
            test/05-common-functions.bats \
            test/06-rotate-aws-backups.bats
fi

# ---------------------------------------------------------------------------
# Stage 3b: Smoke
# ---------------------------------------------------------------------------
# Runs one built-image smoke test for parity with CI.  This catches
# packaging/runtime regressions that source-mounted bats tests cannot detect.
if [[ "${SMOKE}" == "true" ]]; then
    echo "==> Stage 3b: Smoke ${full_image}:${VERSION}" >&2

    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] docker inspect --format '{{json .Config.Entrypoint}}' '${full_image}:${VERSION}' | grep -Fx '[\"/usr/local/bin/rotate-aws-backups\"]'" >&2
        echo "[DRY RUN] docker run --rm '${full_image}:${VERSION}' --help > /dev/null" >&2
    else
        docker inspect --format '{{json .Config.Entrypoint}}' "${full_image}:${VERSION}" \
            | grep -Fx '["/usr/local/bin/rotate-aws-backups"]'
        docker run --rm "${full_image}:${VERSION}" --help > /dev/null
    fi
fi

# ---------------------------------------------------------------------------
# Stage 3c: Coverage (kcov — advisory, never blocks)
#
# Reruns the bats suite through kcov to produce a per-file line-coverage
# report for src/.  Uses 1121citrus/bats-kcov (kcov + bats + jq pre-bundled).
# Requires SYS_PTRACE; works on macOS Docker Desktop with the flags below.
# ---------------------------------------------------------------------------
if [[ "${TEST}" == "true" && "${COVERAGE}" == "true" ]]; then
    echo "==> Stage 3c: Coverage" >&2

    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] docker run --rm --cap-add SYS_PTRACE --security-opt seccomp=unconfined \\" >&2
        echo "[DRY RUN]   -v ${script_dir}:/code:ro -w /code ${BATS_KCOV_IMAGE}:${BATS_KCOV_TAG} bats-coverage <test files>" >&2
    else
        docker run --rm \
            --cap-add SYS_PTRACE \
            --security-opt seccomp=unconfined \
            -v "${script_dir}:/code:ro" \
            -w /code \
            "${BATS_KCOV_IMAGE}:${BATS_KCOV_TAG}" \
            bats-coverage \
                test/01-dockerfile.bats \
                test/02-functional.bats \
                test/03-build.bats \
                test/04-image-metadata.bats \
                test/05-common-functions.bats \
                test/06-rotate-aws-backups.bats \
            >&2 || echo "    Coverage run failed (advisory only)" >&2
    fi
fi

# ---------------------------------------------------------------------------
# Stages 4 & 5a: shared image archive
#
# Trivy and Grype receive the image as a tar archive rather than via the
# Docker daemon socket.  The socket mount hangs on macOS Docker Desktop, and
# the archive approach is faster and more portable.
# ---------------------------------------------------------------------------
_scan_tar=""
if [[ "${SCAN}" == "true" || "${ADVISE_GRYPE}" == "true" ]]; then
    _scan_tar=$(mktemp /tmp/image-scan-XXXXXX)
    trap 'rm -f "${_scan_tar}"' EXIT
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] docker save ${full_image}:${VERSION} > ${_scan_tar}" >&2
    else
        docker save "${full_image}:${VERSION}" > "${_scan_tar}"
    fi
fi

# ---------------------------------------------------------------------------
# Stage 4a: Prime Trivy DB (ensure DB exists before scan)
# ---------------------------------------------------------------------------
if [[ "${SCAN}" == "true" ]]; then
    if [[ "${CACHE_SKIP_UPDATE_TRIVY}" != "true" ]]; then
        if ! volume_has_file "${TRIVY_CACHE_VOLUME}" "/cache/db/trivy.db"; then
            echo "==> Stage 4a: Prime Trivy DB" >&2
            echo "    Priming Trivy DB cache (first run)" >&2
            # Prime the DB in a separate step to handle network errors gracefully.
            # Use --skip-update in the actual scan after this completes.
            if ! run docker run --rm \
                -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
                "${TRIVY_IMAGE}:${TRIVY_TAG}" image --quiet --download-db-only; then
                echo "    Warning: could not initialize Trivy DB cache; scan may be slow" >&2
            fi
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Stage 4: Scan (Trivy)
# ---------------------------------------------------------------------------
if [[ "${SCAN}" == "true" ]]; then
    echo "==> Stage 4: Scan ${full_image}:${VERSION}" >&2

    # Always skip DB update in the actual scan since we primed it in stage 4a.
    # This avoids network downloads during the scan and respects --cache skip-update.
    _trivy_db_flags=(--skip-db-update --skip-java-db-update)
    if [[ "${CACHE_SKIP_UPDATE_TRIVY}" == "true" ]]; then
        echo "    Trivy DB update skipped for this run (--cache skip-update=trivy)" >&2
    fi

    run docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
        "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
            --quiet \
            --no-progress \
            --exit-code 1 \
            --ignore-unfixed \
            --severity HIGH,CRITICAL \
            --timeout 5m \
            "${_trivy_db_flags[@]}" \
            --input /scan.tar
fi

# ---------------------------------------------------------------------------
# Stage 5a: Advise (Grype — non-gating)
# Runs a full-severity Grype scan and prints findings to the build log.
# Never sets a non-zero exit code due to vulnerability findings; the build
# continues regardless of what Grype reports.
# ---------------------------------------------------------------------------
if [[ "${ADVISE_GRYPE}" == "true" ]]; then
    echo "==> Stage 5a: Advise (Grype) ${full_image}:${VERSION}" >&2

    # Initialize the Grype DB cache on first run so the advisement can execute
    # without requiring a separate manual bootstrap step.
    _grype_run_scan=true

    if ! grype_db_ready "${GRYPE_CACHE_VOLUME}"; then
        echo "    No Grype DB cache found in volume; priming ${GRYPE_CACHE_VOLUME}" >&2
    fi

    if [[ "${CACHE_SKIP_UPDATE_GRYPE}" == "true" ]]; then
        echo "    Grype DB update skipped for this run (--cache skip-update=grype)" >&2
        if ! grype_db_ready "${GRYPE_CACHE_VOLUME}"; then
            echo "    Warning: Grype DB cache is empty; skipping Grype advisement" >&2
            _grype_run_scan=false
        fi
    elif ! grype_db_ready "${GRYPE_CACHE_VOLUME}"; then
        echo "    Priming Grype DB cache (first run)" >&2
        if ! _timed 300 docker run --rm \
            -e "GRYPE_DB_CACHE_DIR=${GRYPE_DB_CACHE_DIR}" \
            -v "${GRYPE_CACHE_VOLUME}:${GRYPE_DB_CACHE_DIR}" \
            "${GRYPE_IMAGE}:${GRYPE_TAG}" db update --quiet; then
            echo "    Warning: could not initialize Grype DB cache; skipping Grype advisement" >&2
            _grype_run_scan=false
        fi
    fi

    if [[ "${_grype_run_scan}" == "true" ]]; then
        _timed 300 docker run --rm \
            -v "${_scan_tar}:/scan.tar:ro" \
            -e "GRYPE_DB_CACHE_DIR=${GRYPE_DB_CACHE_DIR}" \
            -v "${GRYPE_CACHE_VOLUME}:${GRYPE_DB_CACHE_DIR}" \
            -e GRYPE_DB_AUTO_UPDATE=false \
            "${GRYPE_IMAGE}:${GRYPE_TAG}" \
                docker-archive:/scan.tar || {
            echo "    Grype scan timed out or failed (advisory only)" >&2
        }
    fi
fi

# Clean up shared scan archive.
if [[ -n "${_scan_tar}" ]]; then
    rm -f "${_scan_tar}"
    trap - EXIT
fi

# ---------------------------------------------------------------------------
# Stage 5b: Advise (Docker Scout — non-gating)
# Invokes the Docker Scout CLI plugin; skips cleanly if the plugin image is
# unavailable (e.g. a pinned docker/scout-cli version not yet on Docker Hub).
# Never sets a non-zero exit code; the build continues regardless.
# ---------------------------------------------------------------------------
if [[ "${ADVISE_SCOUT}" == "true" ]]; then
    echo "==> Stage 5b: Advise (Scout) ${full_image}:${VERSION}" >&2
    if [[ "${DRY_RUN}" == "true" ]]; then
        run docker scout cves "${full_image}:${VERSION}" || true
    else
        set +e
        _scout_out=$(docker scout cves "${full_image}:${VERSION}" 2>&1)
        _scout_status=$?
        set -e
        if [[ ${_scout_status} -ne 0 ]] && echo "${_scout_out}" | grep -qiE 'not found|cannot pull|failed to resolve'; then
            echo "    Scout advisory skipped: docker/scout-cli image unavailable." >&2
        else
            echo "${_scout_out}" >&2
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Stage 5c: Advise (Dive — non-gating)
# Analyzes image layers for bloat, optimization opportunities, and composition.
# Pre-checks Docker daemon API version compatibility before invoking Dive;
# skips cleanly if the daemon requires a newer API than the Dive image supports.
# Never sets a non-zero exit code; the build continues regardless.
# ---------------------------------------------------------------------------
if [[ "${ADVISE_DIVE}" == "true" ]]; then
    echo "==> Stage 5c: Advise (Dive) ${full_image}:${VERSION}" >&2
    daemon_min_api=$(docker version --format '{{.Server.MinAPIVersion}}' 2>/dev/null || true)
    if [[ -n "${daemon_min_api}" ]] && [[ "$(printf '%s\n' "${DIVE_DOCKER_CLIENT_API}" "${daemon_min_api}" | sort -V | tail -n1)" == "${daemon_min_api}" ]] && [[ "${daemon_min_api}" != "${DIVE_DOCKER_CLIENT_API}" ]]; then
        echo "    Skipping Dive advisement: daemon requires Docker API >= ${daemon_min_api}, but ${DIVE_IMAGE}:${DIVE_TAG} uses client API ${DIVE_DOCKER_CLIENT_API}." >&2
    else
        _dive_ci_config=()
        if [[ -f "${script_dir}/.dive-ci" ]]; then
            _dive_ci_config=(-v "${script_dir}/.dive-ci:/.dive-ci:ro")
        fi
        run docker run --rm \
            -v /var/run/docker.sock:/var/run/docker.sock:ro \
            "${_dive_ci_config[@]}" \
            "${DIVE_IMAGE}:${DIVE_TAG}" \
                --source docker \
                --ci \
                --ci-config /.dive-ci \
                "${full_image}:${VERSION}" || true
    fi
fi

# ---------------------------------------------------------------------------
# Stage 6: Push (multi-platform)
# Only runs when --push is specified; rebuilds for all target platforms.
# ---------------------------------------------------------------------------
if [[ "${PUSH}" == "true" ]]; then
    echo "==> Stage 6: Push ${full_image}:${VERSION} (${PLATFORMS})" >&2

    if [[ "${PROVENANCE}" == "true" ]]; then
        provenance_flag="--provenance=mode=max"
    else
        provenance_flag="--provenance=false"
    fi

    push_cmd=(
        docker buildx build
        --platform "${PLATFORMS}"
        "${tags[@]}"
        "${rotate_build_arg[@]}"
        "${version_build_arg[@]}"
        "--sbom=${SBOM}"
        "${provenance_flag}"
        --push
    )

    if [[ -n "${BUILD_EXTRA_ARGS:-}" ]]; then
        # shellcheck disable=SC2206
        push_cmd+=(${BUILD_EXTRA_ARGS})
    fi

    push_cmd+=("${script_dir}")

    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] Would execute:" >&2
        printf '  %s \\\n' "${push_cmd[@]}"
    else
        "${push_cmd[@]}"
    fi
fi

echo "" >&2
echo "Done: ${full_image}:${VERSION}" >&2
