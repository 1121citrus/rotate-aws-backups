function is_false() {
    is-false "${@}"
}

function is_true() {
    is-true "${@}"
}

function is-false() {
    ! is-true "${@}"
}

function is-true() {
    local value
    if [[ "${#@}" = "0" ]]; then
        value=$(cat /dev/stdin | head -n 1)
    else
        value="$*"
    fi
    [[ "${value,,}" =~ ^(1|on|true|t|yes|y)$ ]]
}

# Exit codes
# Define standard exit codes if not already defined
# EXIT_SUCCESS: Successful completion
[[ -z "${EXIT_SUCCESS:+x}" ]]    && readonly EXIT_SUCCESS=0     && export EXIT_SUCCESS
# EXIT_ERROR: General error
[[ -z "${EXIT_ERROR:+x}" ]]      && readonly EXIT_ERROR=1       && export EXIT_ERROR
# EXIT_USAGE: Command line usage error
[[ -z "${EXIT_USAGE:+x}" ]]      && readonly EXIT_USAGE=2       && export EXIT_USAGE
# EXIT_CONFIG: Configuration error
[[ -z "${EXIT_CONFIG:+x}" ]]     && readonly EXIT_CONFIG=3      && export EXIT_CONFIG
# EXIT_NOTFOUND: Resource not found
[[ -z "${EXIT_NOTFOUND:+x}" ]]   && readonly EXIT_NOTFOUND=4    && export EXIT_NOTFOUND
# EXIT_FATAL: Fatal error
[[ -z "${EXIT_FATAL:+x}" ]]      && readonly EXIT_FATAL=5       && export EXIT_FATAL

# Return codes
# Define standard return codes if not already defined
# RETURN_SUCCESS: Successful completion
[[ -z "${RETURN_SUCCESS:+x}" ]]  && readonly RETURN_SUCCESS=0   && export RETURN_SUCCESS
# RETURN_ERROR_FLOOR: Minimum error return code
[[ -z "${RETURN_ERROR_FLOOR:+x}" ]] && readonly RETURN_ERROR_FLOOR=10    && export RETURN_ERROR_FLOOR
# RETURN_ERROR: General error
[[ -z "${RETURN_ERROR:+x}" ]]    && readonly RETURN_ERROR=11    && export RETURN_ERROR
# RETURN_USAGE: Command line usage error
[[ -z "${RETURN_USAGE:+x}" ]]    && readonly RETURN_USAGE=12    && export RETURN_USAGE
# RETURN_CONFIG: Configuration error
[[ -z "${RETURN_CONFIG:+x}" ]]   && readonly RETURN_CONFIG=13   && export RETURN_CONFIG
# RETURN_NOTFOUND: Resource not found
[[ -z "${RETURN_NOTFOUND:+x}" ]] && readonly RETURN_NOTFOUND=14 && export RETURN_NOTFOUND
# RETURN_FATAL: Fatal error
[[ -z "${RETURN_FATAL:+x}" ]]    && readonly RETURN_FATAL=15    && export RETURN_FATAL

# Logging levels
# Define logging levels if not already defined
# These levels are used to control the verbosity of logging output.
# LOG_DIAG: Diagnostic-level logging (least severe)
[[ -z "${LOG_DIAG:+x}" ]]        && readonly LOG_DIAG=0         && export LOG_DIAG
# LOG_TRACE: Trace-level logging
[[ -z "${LOG_TRACE:+x}" ]]       && readonly LOG_TRACE=10       && export LOG_TRACE
# LOG_DEBUG: Debug-level logging
[[ -z "${LOG_DEBUG:+x}" ]]       && readonly LOG_DEBUG=20       && export LOG_DEBUG
# LOG_INFO: Information-level logging
[[ -z "${LOG_INFO:+x}" ]]        && readonly LOG_INFO=30        && export LOG_INFO
# LOG_NOTICE: Notice-level logging
[[ -z "${LOG_NOTICE:+x}" ]]      && readonly LOG_NOTICE=40      && export LOG_NOTICE
# LOG_WARN: Warning-level logging
[[ -z "${LOG_WARN:+x}" ]]        && readonly LOG_WARN=50        && export LOG_WARN
# LOG_ERROR: Error-level logging
[[ -z "${LOG_ERROR:+x}" ]]       && readonly LOG_ERROR=60       && export LOG_ERROR
# LOG_FATAL: Fatal-level logging (most severe)
[[ -z "${LOG_FATAL:+x}" ]]       && readonly LOG_FATAL=70       && export LOG_FATAL

# Default logging level. The user can override this by setting the LOG_LEVEL
[[ -z "${DEFAULT_LOG_LEVEL:-}" ]] && export DEFAULT_LOG_LEVEL && readonly DEFAULT_LOG_LEVEL='info'

# Default log date format. The user can override this by setting the LOG_DATE_FORMAT
[[ -z "${DEFAULT_LOG_DATE_FORMAT:-}" ]] && DEFAULT_LOG_DATE_FORMAT="%Y%m%dT%H%M%S" && export DEFAULT_LOG_DATE_FORMAT

function debug() {
    # Log a debug-level message. This logging level is less
    # severe than 'info' but more severe than 'trace'. It is
    # typically used for debugging information useful during
    # development or troubleshooting.
    # Usage:
    #   debug [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; log DEBUG "$@")
}

function diag() {
    # Log a diagnostic-level message. This logging level is less
    # severe than 'trace' and is typically used for detailed
    # diagnostic information useful during development or troubleshooting.
    # This level is intended to be used sparingly for very detailed messages.
    # Usage:
    #   debug [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; log DIAG "$@")
}

function diagnostic() {
    # Log a diagnostic-level message. This is an alias for 'diag'.
    # Usage:
    #   debug [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; diag "$@")
}

function die() {
    # Log a fatal-level message. This is an alias for 'fatal'.
    # Usage:
    #   die [EXIT_STATUS [MESSAGE...]]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; fatal "$@")
}

function error() {
    # Log a error-level message. This logging level is more
    # severe than 'warn' but less severe than 'fatal'.
    # Usage:
    #   error [EXIT_STATUS [MESSAGE...]]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    local exit_status="${EXIT_ERROR}"
    if validate-exit-status "${1:-}" >/dev/null; then
        # First argument is a valid status, so remove it so that only the message remains
        exit_status="${1:-}" && shift
    fi
    (set -o noglob; log-and-exit ERROR "${exit_status:-${EXIT_ERROR}}" "$@")
}

function exit-status-name() {
    # Convert an exit code to its corresponding exit status name.
    # Usage:
    #   exit-status-name status_code
    # Arguments:
    #   STATUS_CODE: Numeric exit code (0-5 for standard exit codes)
    # Returns:
    #   Log level name ("SUCCESS", "ERROR", "USAGE", "CONFIG", "NOTFOUND", "FATAL")
    #   on stdout or fails if STATUS_CODE is invalid or missing
    case "${code:-${1:-}}" in
        "${EXIT_SUCCESS}")   echo "SUCCESS"  && return "${EXIT_SUCCESS}" ;;
        "${EXIT_ERROR}")     echo "ERROR"    && return "${EXIT_SUCCESS}" ;;
        "${EXIT_USAGE}")     echo "USAGE"    && return "${EXIT_SUCCESS}" ;;
        "${EXIT_CONFIG}")    echo "CONFIG"   && return "${EXIT_SUCCESS}" ;;
        "${EXIT_NOTFOUND}")  echo "NOTFOUND" && return "${EXIT_SUCCESS}" ;;
        "${EXIT_FATAL}")     echo "FATAL"    && return "${EXIT_SUCCESS}" ;;
    esac
    return "${RETURN_ERROR}"
}

function fatal() {
    # Log a fatal-level message. This logging level indicates a critical error
    # that typically requires immediate attention and may lead to program
    # termination. This logging level is the most severe. You should use this
    # level sparingly, **only** for unrecoverable errors.
    # Usage:
    #   fatal [EXIT_STATUS [MESSAGE...]]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    local exit_status="${EXIT_FATAL}"
    if validate-exit-status "${1:-}" >/dev/null; then
        # First argument is a valid status, so remove it so that only the message remains
        exit_status="${1:-}" && shift
    fi 
    (set -o noglob; log-and-exit FATAL "${exit_status:-${EXIT_FATAL}}" "$@")
}

function info() {
    # Log a information-level message. This logging level is less
    # severe than 'notice' but more severe than 'debug'.
    # Usage:
    #   info [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; log INFO "$@")
}

function information() {
    # Log a information-level message. This is an alias for 'info'.
    # Usage:
    #   information [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; info "$@")
}

function log() {
    # Write a log message to stderr with optional prolog (timestamp, command, location).
    # Usage:
    #   log [SEVERITY [MESSAGE...]]
    #   echo "message" | log SEVERITY
    # Arguments:
    #   SEVERITY: One of DIAG, TRACE, DEBUG, INFO, NOTICE, WARN, ERROR, FATAL
    #             (case-insensitive; optional; default: INFO)
    #   MESSAGE:  Log message (optional; if omitted, reads from stdin)
    # Environment variables:
    #   LOG_LEVEL: Minimum severity to log (default: info)
    #   LOGGING_INCLUDE_ALL: If true, include timestamp, command, and location in prolog
    #   LOGGING_INCLUDE_TIMESTAMP: If true, include timestamp in prolog
    #   LOGGING_INCLUDE_COMMAND: If true, include command name in prolog
    #   LOGGING_INCLUDE_LOCATION: If true, include caller location in prolog
    # Example:
    #   log INFO "System started"
    #   echo "Something happened" | log WARN

    # Build the prolog now that we have validated severity
    local prolog
    prolog=$(logging-prolog)

    # Extract and validate severity
    local severity="INFO"
    local tmp=
     # The first argument, if it exists, is the severity / logging level of the message
    if tmp=$(logging-severity "$@"); then
        severity="${tmp}" && shift
    fi
    prolog="${prolog}[${severity}] "

    if log-level-enabled "${severity}"; then
        # Time to log the message ...
        # If message arguments are supplied on the command line, log them.
        if [[ -n "${*:-}" ]]; then
            # Message passed on the command line
            echo "${prolog}${*}" >/dev/stderr
        else
            # Messages are supplied from stdin
            while read -r line; do
                echo "${prolog}${line}" >/dev/stderr
            done
        fi
    fi || :
}

function log-and-exit() {
    # Log a message and then exit with the given status.
    # Usage:
    #   log-and-exit [LEVEL [EXIT_STATUS [MESSAGE...]]]
    # Arguments:
    #   LEVEL: One of DIAG, TRACE, DEBUG, INFO, NOTICE, WARN, ERROR, FATAL
    #          (case-insensitive; optional; default: ERROR)
    #   EXIT_STATUS: Numeric exit status (optional; default: EXIT_ERROR)
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    # Environment variables:
    #   LOG_LEVEL: Minimum severity to log (default: info)
    #   LOGGING_INCLUDE_ALL: If true, include timestamp, command, and location in prolog
    #   LOGGING_INCLUDE_TIMESTAMP: If true, include timestamp in prolog
    #   LOGGING_INCLUDE_COMMAND: If true, include command name in prolog
    #   LOGGING_INCLUDE_LOCATION: If true, include caller location in prolog
    # Example:
    #   log-and-exit FATAL "${EXIT_FATAL}" "System aborted"

    # This is a wrapper around `log` that also exits after the message is written.
    # To keep syntax simple, this function's arguments end up being:
    #
    #     [prolog] level exit-status [log message]
    #
    # We need to process enough on the command line to extract the exit status and
    # to construct the underlying `log` command.

    local severity="ERROR"
    local exit_status="${EXIT_ERROR}"
    local tmp="${1:-}"
     # The first argument, if it exists, is the severity / logging level of the message
    if tmp=$(logging-severity "${tmp}"); then
        severity="${tmp}" && shift
    fi
    # The next argument, if it exists, is the exit code. If it is a non-negative integer, use it,
    # otherwise take it along with the rest of the arguments as the message
    tmp="${1:-}"
    if [[ -n "${tmp}" ]] && [[ "${tmp}" =~ ^[[:digit:]]+$ ]]; then
        exit_status="${tmp}" && shift
    fi

    (set -o noglob; log "${severity}" "$@")

    # Now handle exit
    if [[ "${exit_status}" -eq "${RETURN_SUCCESS}" ]] || \
        [[ "${exit_status}" -eq "${EXIT_SUCCESS}" ]] || \
        [[ "${exit_status}" -ge "${RETURN_ERROR_FLOOR}" ]]; then
        if [[ "${exit_status}" -ge "${RETURN_ERROR_FLOOR}" ]]; then
            exit_status=$((exit_status - RETURN_ERROR_FLOOR))
        fi  
        return  "${exit_status}"
    elif [[ "${exit_status}" -eq "${EXIT_USAGE}" ]] && \
        command -v usage >/dev/null; then
        echo
        usage
    fi
    # Disable error traps to avoid recursion
    set +o errtrace && trap - ERR && exit "${exit_status}"
}

function log-level() {
    # Convert a log level name to its numeric value.
    # Usage:
    #   log-level LEVEL
    # Arguments:
    #   LEVEL: One of DIAG, TRACE, DEBUG, INFO, NOTICE, WARN, ERROR, FATAL (case-insensitive)
    # Returns:
    #   Numeric log level value on stdout or fails if LEVEL is invalid
    local level=
    level="${1:-}"
    level="${level,,}"

    case "${level}" in
        diag|diagnostic)  echo "${LOG_DIAG}"   && return "${RETURN_SUCCESS}" ;;
        trace)            echo "${LOG_TRACE}"  && return "${RETURN_SUCCESS}" ;;
        debug)            echo "${LOG_DEBUG}"  && return "${RETURN_SUCCESS}" ;;
        info|information) echo "${LOG_INFO}"   && return "${RETURN_SUCCESS}" ;;
        notice)           echo "${LOG_NOTICE}" && return "${RETURN_SUCCESS}" ;;
        warn|warning)     echo "${LOG_WARN}"   && return "${RETURN_SUCCESS}" ;;
        error)            echo "${LOG_ERROR}"  && return "${RETURN_SUCCESS}" ;;
        fatal|die)        echo "${LOG_FATAL}"  && return "${RETURN_SUCCESS}" ;;
    esac
    return "${RETURN_ERROR}"
}

function log-level-enabled() {
    # Determine if a given log level is enabled based on the current LOG_LEVEL.
    # Usage:
    #   log-level-enabled LEVEL
    # Arguments:
    #   LEVEL: One of DIAG, TRACE, DEBUG, INFO, NOTICE, WARN, ERROR, FATAL (case-insensitive)
    # Returns:
    #   0 if the log level is enabled, 1 otherwise
    local level="${1:-}"
    [[ -n "${level}" ]] || return "${RETURN_ERROR}"

    # Convert message severity and current logging level to compareable values
    local numeric_log_level=
    numeric_log_level=$(log-level "${LOG_LEVEL:=${DEFAULT_LOG_LEVEL:=info}}")
    local numeric_msg_level=
    numeric_msg_level=$(log-level "${level}")

    # Just return happily and silently if the message severity is lower then the
    # current logging level
    [[ "${numeric_msg_level}" -ge "${numeric_log_level}" ]] || return "${RETURN_ERROR}"
}

function logging-prolog() {
    # Build a logging prolog string with optional timestamp, command name, and location.
    # Usage:
    #   logging-prolog
    # Arguments:
    #   None
    # Environment variables:
    #   LOGGING_INCLUDE_ALL: If true, include timestamp, command, and location in prolog
    #   LOGGING_INCLUDE_TIMESTAMP: If true, include timestamp in prolog
    #   LOGGING_INCLUDE_COMMAND: If true, include command name in prolog
    #   LOGGING_INCLUDE_LOCATION: If true, include caller location in prolog
    #   LOG_DATE_FORMAT: Format string for date output
    #   DEFAULT_LOG_DATE_FORMAT: Default date format if LOG_DATE_FORMAT not set
    # Returns:
    #   Prolog string on stdout

    local prolog=

    # Who are we?
    local cmd=
    if is-true "${LOGGING_INCLUDE_ALL:-false}" || \
       is-true "${LOGGING_INCLUDE_COMMAND:-false}" || \
       is-true "${LOGGING_INCLUDE_LOCATION:-false}"; then
        cmd="$(basename -- "${0}") "
        prolog="${cmd}${prolog}"
    fi

    # What time is it?
    local date=
    if is-true "${LOGGING_INCLUDE_ALL:-false}" || \
       is-true "${LOGGING_INCLUDE_TIMESTAMP:-false}"; then
        local fmt
        fmt="${LOG_DATE_FORMAT:-"${DEFAULT_LOG_DATE_FORMAT:-"%Y%m%dT%H%M%S"}"}"
        if [[ ${fmt} != +* ]]; then
            fmt="+${fmt}"
        fi
        date="$(date -- "${fmt}") "
        prolog="${date}${prolog}"
    fi

    # Build the prolog
    if is-true "${LOGGING_INCLUDE_ALL:-false}" || is-true "${LOGGING_INCLUDE_LOCATION:-false}"; then
        prolog="$(logging-get-external-caller): ${prolog}"
    fi

    echo "${prolog}"
}

function logging-severity() {
    # Extract and validate log severity from function arguments.
    # Usage:
    #   logging-severity [SEVERITY] ...
    # Arguments:
    #   SEVERITY: Raw severity argument (optional)
    # Environment variables:
    #   None
    # Returns:
    #   Uppercase valid severity on stdout or fails if SEVERITY is invalid
    local severity="${1:-}"
    log-level "${severity}" >/dev/null && \
    echo "${severity^^}"
}

function log-traceback-trap() {
    # Usage:
    #   trap 'log-traceback-trap' ERR
    #   set -o errtrace
    local ec=$?
    printf '[ERROR] command "%s" exited %s\n' "${BASH_COMMAND}" "${ec}"
    log-traceback
    return "${ec}"
}

function log-traceback() {
    # Log a traceback of the current call stack.
    # Usage:
    #   log-traceback
    # Returns:
    #   Call stack trace logged to stderr
    local i
    # shellcheck disable=SC2119
    (for ((i=0; i<${#FUNCNAME[@]}-1; i++)); do
        printf '%s[%s] in %s()\n'  "${FUNCNAME[${i+1}]}" "${BASH_LINENO[${i}]}"  "${BASH_SOURCE[${i}]}"
    done) | \
    trace
    # Log each line of the traceback as a trace-level message
}

function logging-exit-fatally() {
    # Safely exit with cleanup: disable error traps, then exit.
    # Usage:
    #   logging-exit-fatally [EXIT_CODE]
    # Arguments:
    #   EXIT_CODE: Numeric exit code (default: EXIT_ERROR)
    local code="${1:-${EXIT_ERROR}}"
    # Disable error traps to avoid recursion
    set +o errtrace
    trap - ERR
    exit "${code}"
}

function logging-get-external-caller() {
    # Determine the external caller (function and line number) outside this logging library.
    # Usage:
    #   logging-get-external-caller
    # Returns:
    #   External caller in the form `function_name[line_number]` or
    #   `function_name[line_number]` in filename if `LOGGING_INCLUDE_LOCATION_FILE` is true
    local this_file="${BASH_SOURCE[0]}"

    # n.b. frame < 0 is intentional; any expression that results in `true` will do
    for ((frame = 0 ; -1 < frame ; frame++)); do
        # Get caller info for this stack frame
        local caller_info=()
        read -ra caller_info < <(caller $frame)

        # If caller returns nothing, we've reached the top of the stack
        if [[ ${#caller_info[@]} -eq 0 ]]; then
            echo "unknown[0]"
            return "${RETURN_ERROR}"
        fi

        # Extract caller details
        local lineno="${caller_info[0]}"
        local func_name="${caller_info[1]}"
        local caller_file="${caller_info[2]}"
        local external_caller="${func_name}[${lineno}]"
        # Include filename if requested
        is-true "${LOGGING_INCLUDE_LOCATION_FILE:-false}" && \
            external_caller="${external_caller} in $(basename "${caller_file}")"

        # Check if this caller is from a different file
        # If so, we've found the external caller
        if [[ "${caller_file}" != "${this_file}" ]]; then
            echo "${external_caller}"
            return "${RETURN_SUCCESS}"
        fi
        # Otherwise, continue up the stack
    done
    # If we reach here, we didn't find an external caller
    echo "unknown[0]"
    return "${RETURN_ERROR}"
}

function notice() {
    # Log a notice-level message. This logging level is more
    # severe than 'info' but less severe than 'warn'. This level
    # is typically used for important but non-critical messages.
    # Usage:
    #   notice [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; log NOTICE "$@")
}

function return-status-name() {
    # Convert a return code to its corresponding log level name.
    # Usage:
    #   return-status-name RETURN_CODE
    # Arguments:
    #   RETURN_CODE: Numeric return code (0, 10-15 for standard return codes)
    # Returns:
    #   Log level name ("SUCCESS", "ERROR", "USAGE", "CONFIG", "NOTFOUND", "FATAL")
    #   on stdout or fails if RETURN_CODE is invalid or missing
    local code="${1:-}"
    case "${code}" in
        "${RETURN_SUCCESS}")     echo "SUCCESS"  && return "${RETURN_SUCCESS}" ;;
        "${RETURN_ERROR}")       echo "ERROR"    && return "${RETURN_SUCCESS}" ;;
        "${RETURN_USAGE}")       echo "USAGE"    && return "${RETURN_SUCCESS}" ;;
        "${RETURN_CONFIG}")      echo "CONFIG"   && return "${RETURN_SUCCESS}" ;;
        "${RETURN_NOTFOUND}")    echo "NOTFOUND" && return "${RETURN_SUCCESS}" ;;
        "${RETURN_FATAL}")       echo "FATAL"    && return "${RETURN_SUCCESS}" ;;
    esac
    return "${RETURN_ERROR}"
}

# shellcheck disable=SC2120
function trace() {
    # Log a trace-level message. This logging level is more
    # detailed than 'debug' and is typically used for
    # tracing program execution. This level is usually only
    # enabled during development or troubleshooting and often
    # is used in conjunction with the `LOGGING_INCLUDE_*`
    # environment variables to provide detailed context.
    # Usage:
    #   trace [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; log TRACE "$@")
}

function validate-log-level() {
    local level="${1:?Need level}"
    log-level "${level}" >/dev/null || {
        local cmd=
        {
          is-true "${LOGGING_INCLUDE_ALL:-false}" || \
          is-true "${LOGGING_INCLUDE_COMMAND:-false}"
        } && cmd="$(basename -- "${0}") "
        local date=
        {
          is-true "${LOGGING_INCLUDE_ALL:-false}" || \
          is-true "${LOGGING_INCLUDE_TIMESTAMP:-false}"
        } && date="$(date '+%Y%m%dT%H%M%S') "
        # !! Be sure to use 'echo' so as not to recurse
        echo "${date}${cmd}[FATAL] Invalid log message severity '${level}'" >/dev/stderr || :
        set +o errtrace && trap - ERR && exit "${EXIT_FATAL}"
    }
}

function validate-exit-status() {
    local status="${1:-}"
    [[ "${status}" =~ ^[0-9]+$ ]] && (( status >= 0 && status <= 127 ))
}

function warn() {
    # Log a warning-level message. This logging is level is more
    # severe than 'info' but less severe than 'error'.
    # Usage:
    #   warn [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; log WARN "$@")
}

function warning() {
    # Log a warning-level message. This is an alias for 'warn'.
    # Usage:
    #   warning [MESSAGE...]
    # Arguments:
    #   MESSAGE: Log message (optional; if omitted, reads from stdin)
    (set -o noglob; warn "$@")
}
