# ---------------------------------------------------------------------------
# Shared staging helpers
# ---------------------------------------------------------------------------
# _append_aws_mounts <array_ref>: append -v/-e flags for AWS config and
# credentials mounts to the named array.  _aws_cfg_mount and _aws_creds_mount
# are set and exported by setup() before setup_hooks() runs.
_append_aws_mounts() {
    local -n _amr=$1
    if [[ -r "${_aws_cfg_mount:-/nonexistent}" ]]; then
        _amr+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro"
               -e "AWS_CONFIG_FILE=/run/secrets/aws-config")
    fi
    if [[ -r "${_aws_creds_mount:-/nonexistent}" ]]; then
        _amr+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro"
               -e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
    fi
}

# _wait_for_log_pattern <container> <grep_pattern> <timeout_s>
# Polls docker logs every 10s until <grep_pattern> matches or <timeout_s>
# elapses.  Sets _WAIT_ELAPSED to elapsed seconds.  Progress to stderr.
# Returns 0 if pattern found, 1 if timed out.
_wait_for_log_pattern() {
    local _ctr="$1" _pat="$2" _tmo="$3"
    local _elapsed=0 _interval=10 _last
    _WAIT_ELAPSED=0
    while [[ ${_elapsed} -lt ${_tmo} ]]; do
        sleep "${_interval}"
        _elapsed=$(( _elapsed + _interval ))
        if docker logs "${_ctr}" 2>&1 | grep -q "${_pat}"; then
            _WAIT_ELAPSED=${_elapsed}
            return 0
        fi
        _last=$(docker logs --tail 1 "${_ctr}" 2>&1)
        printf '  [%ds] waiting... (last: %s)\n' "${_elapsed}" "${_last}" >&2
    done
    _WAIT_ELAPSED=${_elapsed}
    return 1
}

