# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------
_set_cache_targets() {
    local mode="$1" targets_csv="$2" target
    IFS=',' read -ra _tgts <<< "${targets_csv,,}"
    for target in "${_tgts[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_TRIVY=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_TRIVY=true
                fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_GRYPE=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_TRIVY=true; _CACHE_RESET_GRYPE=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_TRIVY=true
                    _CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *) echo "Unknown cache target: ${target}" >&2; exit 1 ;;
        esac
    done
}

# _parse_cache_rules — parse semicolon-separated key=value cache rules from
# the --cache flag (e.g. "reset=trivy;skip-update=grype") and call
# _set_cache_targets for each entry.
# Args: $1=rules (semicolon-separated string)
_parse_cache_rules() {
    local rules="$1" entry key value
    IFS=';' read -ra _rules <<< "${rules}"
    for entry in "${_rules[@]}"; do
        key="${entry%%=*}"; value="${entry#*=}"
        key="${key,,}"; key="${key// /}"; value="${value// /}"
        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2; exit 1
        fi
        case "${key}" in
            reset|skip-update) _set_cache_targets "${key}" "${value}" ;;
            *) echo "Unknown --cache rule key: ${key}" >&2; exit 1 ;;
        esac
    done
}

# _reset_cache_db — wipe and recreate a Docker volume used as a scanner DB
# cache (Trivy or Grype).  Runs Alpine inside a container so the operation
# is cross-platform and independent of host filesystem permissions.
# Args: $1=volume_name
_reset_cache_db() {
    local volume_name="$1"
    docker run --rm \
        -v "${volume_name}:/cache" \
        "${ALPINE_IMAGE}:${ALPINE_TAG}" \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

# show_help — print the SYNOPSIS section of this staging script to stdout.
# Reads from the script's own header comment block (between "# SYNOPSIS" and
# the first "set -" line), stripping the leading "# " prefix.
# Args: none
show_help() {
    sed -n '/^# SYNOPSIS/,/^set -/p' "$0" \
        | grep '^#' \
        | sed 's/^# \{0,1\}//'
}

_SKIP_COUNT=0
# _skip — record a skipped test and increment the global skip counter.
# Prints a SKIP line to stdout (picked up by run_tests summary) using
# FUNCNAME[1] so the skipping test's name appears in the output.
# Args: $@=reason message
_skip() {
    echo "SKIP '${FUNCNAME[1]}': $*"
    (( ++_SKIP_COUNT )) || true
}

# _aws_available — return 0 if AWS credentials are present for the test run.
# Requires S3_BUCKET_NAME or BUCKET_LIST to be non-empty AND at least one of:
# aws-config file readable, aws-credentials file readable, or
# AWS_ACCESS_KEY_ID env var set.
# Args: none
_aws_available() {
    local bucket="${S3_BUCKET_NAME:-${BUCKET_LIST:-}}"
    [[ -n "${bucket}" ]] && {
        [[ -r "${_aws_cfg:-/nonexistent}" ]] || \
        [[ -r "${_aws_creds:-/nonexistent}" ]] || \
        [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]
    }
}

# ---------------------------------------------------------------------------
# setup — verify image, copy credentials, create scan archive, call hooks
# ---------------------------------------------------------------------------
setup() {
    [[ -n "${IMAGE}" ]] || {
        echo "ERROR: IMAGE is not set" >&2
        echo "       Pass it as a positional arg or use --image IMAGE" >&2
        return 1
    }
    docker image inspect "${IMAGE}" > /dev/null 2>&1 || {
        echo "ERROR: image not found locally: ${IMAGE}" >&2
        echo "       Pull or build it first: ./build --no-scan" >&2
        return 1
    }

    # Verify exec-form ENTRYPOINT (not legacy shell-form).
    local ep
    ep=$(docker inspect "${IMAGE}" --format '{{json .Config.Entrypoint}}' 2>/dev/null || echo "")
    if [[ "${ep}" != '["/usr/local/bin/rotate-aws-backups"]' ]]; then
        echo "ERROR: unexpected ENTRYPOINT in ${IMAGE}" >&2
        echo "       Got:      ${ep}" >&2
        echo '       Expected: ["/usr/local/bin/rotate-aws-backups"]' >&2
        echo "       Rebuild: ./build --no-scan" >&2
        return 1
    fi
    if ! docker run --rm --entrypoint test "${IMAGE}" \
            -x /usr/local/bin/rotate-aws-backups > /dev/null 2>&1; then
        echo "ERROR: /usr/local/bin/rotate-aws-backups not found in ${IMAGE}" >&2
        echo "       Rebuild: ./build --no-scan" >&2
        return 1
    fi

    # AWS credential temp copies (world-readable for UID 10001 inside container)
    _aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"
    _aws_cfg_mount="${_aws_cfg}"
    if [[ -r "${_aws_cfg}" ]]; then
        _aws_cfg_mount=$(mktemp /tmp/aws-config-staging-XXXXXX)
        cp "${_aws_cfg}" "${_aws_cfg_mount}"
        chmod 0644 "${_aws_cfg_mount}"
    fi
    export _aws_cfg_mount

    _aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    _aws_creds_mount="${_aws_creds}"
    if [[ -r "${_aws_creds}" ]]; then
        _aws_creds_mount=$(mktemp /tmp/aws-credentials-staging-XXXXXX)
        cp "${_aws_creds}" "${_aws_creds_mount}"
        chmod 0644 "${_aws_creds_mount}"
    fi
    export _aws_cfg _aws_creds _aws_creds_mount

    # Scan archive (shared by Trivy, Grype, and Dive; avoids Docker socket mount)
    _scan_tar=""
    if [[ "${_SCAN}" == "true" || "${_ADVISE_GRYPE}" == "true" \
            || "${_ADVISE_DIVE}" == "true" ]]; then
        _scan_tar=$(mktemp /tmp/staging-scan-XXXXXX)
        docker save "${IMAGE}" > "${_scan_tar}"
    fi
    export _scan_tar

    # shellcheck disable=SC2064
    trap 'rm -f "${_aws_cfg_mount}" "${_aws_creds_mount}" "${_scan_tar}"' EXIT

    # Call repo-specific hook for docker-run helper definitions
    if declare -F setup_hooks > /dev/null 2>&1; then
        setup_hooks
    fi
}

# ---------------------------------------------------------------------------
# Scan / advise tests
# ---------------------------------------------------------------------------
test_staging_trivy_scan() {
    [[ "${_SCAN}" == "true" ]] || {
        _skip "--no-scan: Trivy scan skipped"; return 0; }
    printf '  running Trivy scan on %s...\n' "${IMAGE}" >&2
    local _extra=()
    [[ "${_CACHE_SKIP_UPDATE_TRIVY}" == "true" ]] && {
        echo "    Trivy DB update skipped (--cache skip-update=trivy)" >&2
        _extra+=(--skip-db-update --skip-java-db-update); }
    local _trivyign_v=() _trivyign_a=()
    if [[ -n "${_TRIVY_IGNOREFILE:-}" ]]; then
        local _repo_dir
        _repo_dir="$(dirname "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")")"
        if [[ -f "${_repo_dir}/${_TRIVY_IGNOREFILE}" ]]; then
            _trivyign_v+=(-v "${_repo_dir}/${_TRIVY_IGNOREFILE}:/.trivyignore:ro")
            _trivyign_a+=(--ignorefile /.trivyignore)
        fi
    fi
    local result=0
    docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
        "${_trivyign_v[@]}" \
        "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
            --quiet --no-progress --exit-code 1 \
            --ignore-unfixed --severity HIGH,CRITICAL \
            "${_trivyign_a[@]}" \
            --timeout 5m \
            "${_extra[@]}" \
            --input /scan.tar 2>&1 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': no unfixed HIGH/CRITICAL CVEs found"
    else
        echo "FAIL '${FUNCNAME[0]}': unfixed HIGH/CRITICAL CVEs found (exit=${result})"
        return 1
    fi
}

# test_staging_grype_advise — run a Grype advisory scan against the staged
# image archive.  Skipped when _ADVISE_GRYPE is not "true".  Never returns
# non-zero (advisory only); scan output goes to stdout for the log.
# Args: none (uses IMAGE, _scan_tar, GRYPE_* globals)
test_staging_grype_advise() {
    [[ "${_ADVISE_GRYPE}" == "true" ]] || {
        _skip "--no-advise grype: Grype advisory scan skipped"; return 0; }
    printf '  running Grype advisory scan on %s...\n' "${IMAGE}" >&2
    local _extra=()
    [[ "${_CACHE_SKIP_UPDATE_GRYPE}" == "true" ]] && {
        echo "    Grype DB update skipped (--cache skip-update=grype)" >&2
        _extra+=(-e GRYPE_DB_AUTO_UPDATE=false); }
    docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        -v "${GRYPE_CACHE_VOLUME}:/root/.cache/grype" \
        "${_extra[@]}" \
        "${GRYPE_IMAGE}:${GRYPE_TAG}" \
            docker-archive:/scan.tar 2>&1 || true
    echo "PASS '${FUNCNAME[0]}': Grype advisory scan complete (advisory only)"
}

