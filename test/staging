# test/staging — functional staging tests for rotate-aws-backups.
#
# SYNOPSIS
#   test/staging [--image IMAGE]
#                [--bucket BUCKET]
#                [--aws-credentials FILE]
#                [--dryrun | --no-dryrun]
#                [--scan | --no-scan]
#                [--advise [ADVISEMENTS] | --no-advise]
#                [--cache CACHE_RULES]
#                [--skip-e2e] [--test NAME] [--help]
#
# OPTIONS
#   --image IMAGE    Docker image to test (positional arg also accepted).
#   --bucket BUCKET  S3 bucket for backup/restore tests.
#   --aws-credentials FILE
#                    Path to AWS credentials file.
#   --dryrun         Pass --dryrun to the container command.
#   --no-dryrun      Disable dryrun mode.
#   --scan           Run Trivy CVE scan (gating). Default: on.
#   --no-scan        Skip the Trivy scan.
#   --advise [LIST]  Advisory scans: dive,grype,scout,coverage,all.
#   --no-advise      Disable all advisory scans.
#   --cache CACHE_RULES
#                    One-run cache controls (reset=all, skip-update=trivy).
#   --skip-e2e       Skip tests flagged as destructive/end-to-end.
#   --test NAME      Run only the named test function.
#   -h|--help        Print this message and exit.
#

