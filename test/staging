_ADVISE_COVERAGE=false  # --advise coverage: run kcov (advisory; never gates)
_ADVISE_DIVE=false      # --advise dive: Dive layer analysis (advisory)
_ADVISE_GRYPE=false     # --advise grype: Grype full-severity scan (advisory)
_ADVISE_SCOUT=false     # --advise scout: Docker Scout scan (advisory)
