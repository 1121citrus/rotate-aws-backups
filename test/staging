#!/usr/bin/env bash

# test/staging — functional tests for rotate-aws-backups against live AWS.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# These tests exercise the rotate-aws-backups CLI end-to-end with no stubs.
# Tests that require a live S3 bucket are skipped (not failed) when BUCKET
# is unset or AWS credentials are unavailable.
#
# IAM permissions required:
#   Production tests (test_staging_cli_dryrun, test_staging_cron_fires):
#     s3:ListBucket       on arn:aws:s3:::${BUCKET}
#     s3:ListBucket       on arn:aws:s3:::${BUCKET}/*
#   End-to-end correctness test (test_staging_rotation_e2e):
#     All of the above PLUS on arn:aws:s3:::test.rotate-aws-backups-*:
#     s3:CreateBucket, s3:DeleteBucket
#     s3:PutObject, s3:GetObject, s3:ListBucket, s3:DeleteObject
#
# SYNOPSIS
#   test/staging [options] [IMAGE]
#
# OPTIONS
#   IMAGE                     Docker image to test (positional; also --image)
#   --image IMAGE             Docker image to test (env: IMAGE)
#   --bucket BUCKET           S3 bucket to rotate (env: BUCKET)
#   --bucket-list LIST        Space-separated bucket list (env: BUCKET_LIST)
#   --aws-config FILE         AWS config file path
#                             (env: AWS_CONFIG_FILE;
#                             default: ~/.secrets/aws-config)
#   --aws-credentials FILE    AWS credentials file path
#                             (env: AWS_CREDENTIALS_FILE;
#                             default: ~/.secrets/aws-credentials)
#   --dryrun                  Enable dry-run for production bucket tests
#                             (env: DRYRUN; default: true)
#   --no-dryrun               Disable dry-run for production bucket tests
#   --scan                    Run Trivy HIGH/CRITICAL scan on the image
#                             (env: STAGING_SCAN; default: true)
#   --no-scan                 Skip Trivy scan; implies --no-advise unless
#                             --advise is given explicitly
#   --no-coverage             Skip kcov coverage report (advisory only)
#   --advise [LIST]           Run advisory scans: coverage,grype,scout,dive,all
#                             (default list when LIST omitted: grype,scout)
#   --no-advise               Disable all advisory scans
#   --cache RULES             Scanner DB cache controls; RULES is semicolon-
#                             separated key=targets pairs; keys: reset,
#                             skip-update; targets: trivy,grype,all
#                             e.g. 'reset=all' or 'skip-update=grype'
#   --yes                     Skip the "yes" confirmation prompt
#   --skip-e2e                Skip test_staging_rotation_e2e
#   --test TEST               Run only the named test function
#   -h, --help                Print this message and exit
#
# ENVIRONMENT
#   IMAGE              Docker image to test
#   BUCKET             S3 bucket to rotate (single bucket)
#   BUCKET_LIST        Space-separated list of buckets (default: BUCKET)
#   AWS_CONFIG_FILE      Path to AWS config file
#   AWS_CREDENTIALS_FILE Path to AWS credentials file
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
#                        Inline AWS credentials (alternative to config/credentials files)
#   DRYRUN             true = dry-run for production bucket tests (default)
#                      false = live deletions (test/staging buckets only)
#   STAGING_SCAN       true/false — controls Trivy scan (default: true)
#   DOCKER_RUN_ARGS    Extra flags appended to every docker run invocation
#
# EXAMPLES
#   # AWS-independent smoke tests (no credentials needed):
#   test/staging 1121citrus/rotate-aws-backups:latest
#
#   # Quick iteration — skip scan:
#   test/staging --no-scan 1121citrus/rotate-aws-backups:latest
#
#   # Full suite with all advisory scans and fresh scanner DBs:
#   test/staging --no-dryrun --cache reset=all --advise all \
#       --bucket test.my-backups \
#       --aws-config ~/.secrets/aws-config \
#       1121citrus/rotate-aws-backups:latest
#
#   # Run all three advisory scanners:
#   test/staging --advise grype,scout,dive 1121citrus/rotate-aws-backups:latest
#
#   # Reset scanner DB caches for this run, then skip Grype DB update:
#   test/staging --cache 'reset=all;skip-update=grype' \
#       1121citrus/rotate-aws-backups:latest
#
#   # Skip confirmation prompt (CI / scripted use):
#   test/staging --bucket test.my-backups --yes \
#       1121citrus/rotate-aws-backups:latest
#
#   # Run only the end-to-end rotation correctness test:
#   test/staging --bucket test.my-backups \
#       --test test_staging_rotation_e2e \
#       1121citrus/rotate-aws-backups:latest
#
#   # Skip e2e test when credentials lack s3:CreateBucket:
#   test/staging --bucket my-backups --skip-e2e \
#       1121citrus/rotate-aws-backups:latest

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults — overridden by environment variables, then by CLI flags.
# ---------------------------------------------------------------------------
IMAGE="${IMAGE:-}"
BUCKET="${BUCKET:-}"
BUCKET_LIST="${BUCKET_LIST:-}"
AWS_CONFIG_FILE="${AWS_CONFIG_FILE:-}"
AWS_CREDENTIALS_FILE="${AWS_CREDENTIALS_FILE:-}"
DRYRUN="${DRYRUN:-true}"
_YES=false
_SKIP_E2E=false
_ONLY_TEST=""
_SCAN="${STAGING_SCAN:-true}"
_ADVISE_COVERAGE=false
_ADVISE_DIVE=false
_ADVISE_GRYPE=false
_ADVISE_SCOUT=false
_ADVISE_EXPLICIT=false   # set to true when --advise or --no-advise is passed
_CACHE_RESET_TRIVY=false
_CACHE_RESET_GRYPE=false
_CACHE_SKIP_UPDATE_TRIVY=false
_CACHE_SKIP_UPDATE_GRYPE=false

# Tool image refs — keep in sync with the top-level build script.
BATS_KCOV_IMAGE=1121citrus/bats-kcov
BATS_KCOV_TAG=latest
DIVE_IMAGE=wagoodman/dive
DIVE_TAG=v0.13.1
GRYPE_IMAGE=anchore/grype
GRYPE_TAG=v0.87.0
TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.62.1

# Named Docker volumes for scanner DB caches (avoid host-path coupling).
TRIVY_CACHE_VOLUME=rotate-aws-backups-staging-trivy-cache
GRYPE_CACHE_VOLUME=rotate-aws-backups-staging-grype-cache

_set_cache_targets() {
    local mode="$1" targets_csv="$2" target
    IFS=',' read -ra _tgts <<< "${targets_csv,,}"
    for target in "${_tgts[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_TRIVY=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_TRIVY=true; fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_GRYPE=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_GRYPE=true; fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_TRIVY=true; _CACHE_RESET_GRYPE=true
                fi
                if [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_TRIVY=true; _CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *) echo "Unknown cache target: ${target}" >&2; exit 1 ;;
        esac
    done
}

_parse_cache_rules() {
    local rules="$1" entry key value
    IFS=';' read -ra _rules <<< "${rules}"
    for entry in "${_rules[@]}"; do
        key="${entry%%=*}"; value="${entry#*=}"
        key="${key,,}"; key="${key// /}"; value="${value// /}"
        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2; exit 1
        fi
        case "${key}" in
            reset|skip-update) _set_cache_targets "${key}" "${value}" ;;
            *) echo "Unknown --cache rule key: ${key}" >&2; exit 1 ;;
        esac
    done
}

_reset_cache_db() {
    local volume_name="$1"
    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.21 \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

show_help() {
    # Extract the header comment from SYNOPSIS through EXAMPLES (inclusive).
    sed -n '/^# SYNOPSIS/,/^set -/p' "$0" \
        | grep '^#' \
        | sed 's/^# \{0,1\}//'
}

setup() {
    [[ -n "${IMAGE}" ]] || {
        echo "ERROR: IMAGE is not set" >&2
        echo "       Pass it as a positional arg or use --image IMAGE" >&2
        return 1
    }
    docker image inspect "${IMAGE}" > /dev/null 2>&1 || {
        echo "ERROR: image not found locally: ${IMAGE}" >&2
        echo "       Pull or build it first: ./build --no-scan" >&2
        return 1
    }

    # Verify the image uses the exec-form ENTRYPOINT, not the legacy
    # shell-form ENTRYPOINT ["/bin/sh","-c"] + CMD ["/usr/local/bin/startup"].
    # With the legacy form, CLI args like --help replace CMD and are passed to
    # /bin/sh as options, causing all CLI-flag tests to fail with exit 2.
    local ep
    ep=$(docker inspect "${IMAGE}" --format '{{json .Config.Entrypoint}}' \
             2>/dev/null || echo "")
    if [[ "${ep}" != '["/usr/local/bin/rotate-aws-backups"]' ]]; then
        echo "ERROR: unexpected ENTRYPOINT in ${IMAGE}" >&2
        echo "       Got:      ${ep}" >&2
        echo "       Expected: [\"/usr/local/bin/rotate-aws-backups\"]" >&2
        echo "       The Hub image is stale. Rebuild and test against the" >&2
        echo "       local dev image: ./build --no-scan" >&2
        return 1
    fi

    # Verify the entrypoint exists before any test runs.
    # Exit 127 from individual tests is confusing; a clear setup failure
    # is not.  This catches a stale 'latest' image before publishing a new
    # version — rebuild with: IMAGE=... ./build --no-scan
    if ! docker run --rm --entrypoint test "${IMAGE}" \
            -x /usr/local/bin/rotate-aws-backups > /dev/null 2>&1; then
        echo "ERROR: /usr/local/bin/rotate-aws-backups not found in ${IMAGE}" >&2
        echo "       Rebuild: ./build --no-scan" >&2
        return 1
    fi

    # Resolve the AWS config file path once so each test does not re-derive it.
    _aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"

    # The image now runs as a non-root user (UID 10001).  A mode-600 config
    # file owned by the host user is unreadable by that UID inside the
    # container.  Create a world-readable temp copy for the duration of the
    # test run — the temp file is removed on EXIT below.
    _aws_cfg_mount="${_aws_cfg}"
    if [[ -r "${_aws_cfg}" ]]; then
        _aws_cfg_mount=$(mktemp /tmp/aws-config-staging-XXXXXX)
        cp "${_aws_cfg}" "${_aws_cfg_mount}"
        chmod 0644 "${_aws_cfg_mount}"
    fi
    export _aws_cfg_mount

    # Resolve the AWS credentials file; create a world-readable temp copy for
    # the non-root container user (UID 10001), same as the config file above.
    _aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    _aws_creds_mount="${_aws_creds}"
    if [[ -r "${_aws_creds}" ]]; then
        _aws_creds_mount=$(mktemp /tmp/aws-credentials-staging-XXXXXX)
        cp "${_aws_creds}" "${_aws_creds_mount}"
        chmod 0644 "${_aws_creds_mount}"
    fi
    export _aws_creds _aws_creds_mount

    # Run rotate-aws-backups with staging credentials and the given CLI args.
    # No stubs: the real AWS CLI and real S3 bucket are used.
    # stderr is merged with stdout so callers capture all log output.
    run_rotate_aws_backups() {
        local aws_mounts=() aws_env=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        # shellcheck disable=SC2086
        docker run --rm ${DOCKER_RUN_ARGS:-} \
            -e "BUCKET=${BUCKET:-}" \
            -e "BUCKET_LIST=${BUCKET_LIST:-}" \
            -e "DRYRUN=${DRYRUN:-true}" \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            "${IMAGE}" "$@" 2>&1
    }

    # Start the full service container (scheduler mode) detached.
    # Prints the container ID to stdout; caller is responsible for stop and rm.
    run_service_detached() {
        local aws_mounts=() aws_env=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        # shellcheck disable=SC2086
        docker run -d ${DOCKER_RUN_ARGS:-} \
            -e "BUCKET=${BUCKET:-}" \
            -e "BUCKET_LIST=${BUCKET_LIST:-}" \
            -e "DRYRUN=${DRYRUN:-true}" \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            "$@" \
            "${IMAGE}"
    }

    # Run an aws CLI command inside the image, bypassing the rotate-aws-backups
    # entrypoint.  Used for bucket lifecycle operations in test_staging_rotation_e2e.
    _aws() {
        local aws_mounts=() aws_env=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        # shellcheck disable=SC2086
        docker run --rm --entrypoint /usr/local/bin/aws \
            ${DOCKER_RUN_ARGS:-} \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            -e "AWS_RETRY_MODE=standard" \
            -e "AWS_MAX_ATTEMPTS=5" \
            "${IMAGE}" "$@"
    }

    export _aws_cfg _aws_cfg_mount _aws_creds _aws_creds_mount
    export -f _aws run_rotate_aws_backups run_service_detached

    # Create a shared image archive for Trivy, Grype, and Dive — avoids mounting
    # the Docker socket inside scanner containers, which hangs on macOS Docker Desktop.
    _scan_tar=""
    if [[ "${_SCAN}" == "true" || "${_ADVISE_GRYPE}" == "true" \
            || "${_ADVISE_DIVE}" == "true" ]]; then
        _scan_tar=$(mktemp /tmp/staging-scan-XXXXXX)
        docker save "${IMAGE}" > "${_scan_tar}"
    fi
    export _scan_tar

    # Clean up temp files on exit (world-readable config copy + scan archive).
    # shellcheck disable=SC2064
    trap 'rm -f "${_aws_cfg_mount}" "${_aws_creds_mount}" "${_scan_tar}"' EXIT
}

# _days_ago_ts prints a timestamp N days ago in rotate-backups' default format
# (YYYYMMDDThhmmss at noon UTC).  Handles GNU date (Linux) and BSD date (macOS).
_days_ago_ts() {
    local n="$1"
    date -u -d "${n} days ago" '+%Y%m%dT120000' 2>/dev/null || \
    date -u -v-"${n}"d '+%Y%m%dT120000'
}

# _skip prints a SKIP notice, increments the shared skip counter, and returns 0
# so the test is not counted as a failure.
_SKIP_COUNT=0
_skip() {
    echo "SKIP '${FUNCNAME[1]}': $*"
    (( ++_SKIP_COUNT )) || true
}

# _aws_available returns 0 when a bucket and at least one form of AWS
# credentials are present.
_aws_available() {
    local bucket="${BUCKET:-${BUCKET_LIST:-}}"
    [[ -n "${bucket}" ]] && {
        [[ -r "${_aws_cfg:-/nonexistent}" ]] || \
        [[ -r "${_aws_creds:-/nonexistent}" ]] || \
        [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]
    }
}

# ── AWS-independent tests ─────────────────────────────────────────────────────
# These exercise CLI option parsing only; no bucket connection is attempted.

test_staging_help() {
    local output result=0
    output=$(run_rotate_aws_backups --help 2>&1) || result=$?
    if [[ ${result} -eq 0 ]] && echo "${output}" | grep -q 'Usage:'; then
        echo "PASS '${FUNCNAME[0]}': --help exits 0 and prints usage"
    else
        echo "FAIL '${FUNCNAME[0]}': --help failed (exit=${result})"
        return 1
    fi
}

test_staging_version() {
    local output result=0
    output=$(run_rotate_aws_backups --version 2>&1) || result=$?
    if [[ ${result} -eq 0 ]] && [[ -n "${output}" ]]; then
        echo "PASS '${FUNCNAME[0]}': --version exits 0 and prints: ${output}"
    else
        echo "FAIL '${FUNCNAME[0]}': --version failed (exit=${result})"
        return 1
    fi
}

test_staging_unknown_option() {
    local result=0
    run_rotate_aws_backups --no-such-option > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero for unknown option"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero for unknown option"
        return 1
    fi
}

test_staging_no_bucket_cli_mode() {
    # Run with no BUCKET env so the no-bucket error path is genuinely exercised.
    # Uses plain docker run (not run_rotate_aws_backups) to avoid injecting the
    # caller's BUCKET from the outer environment.
    local result=0
    docker run --rm "${IMAGE}" > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': CLI mode without bucket exits non-zero"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero without bucket"
        return 1
    fi
}

test_staging_cron_no_bucket() {
    # Scheduler mode must also validate bucket presence before exec'ing crond.
    # Uses plain docker run for the same reason as test_staging_no_bucket_cli_mode.
    local result=0
    docker run --rm "${IMAGE}" --cron > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': --cron without bucket exits non-zero"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero without bucket"
        return 1
    fi
}

# test_staging_cron_startup: verify the scheduler container starts, writes its
# crontab, and stays running — no AWS credentials required.
# Catches Dockerfile permission regressions (e.g. /var/spool/cron/crontabs
# root-owned via Alpine symlink) that CLI-mode tests cannot exercise.
test_staging_cron_startup() {
    local container_id
    # Use @daily so the job never fires during the test window.
    # shellcheck disable=SC2086
    container_id=$(docker run -d ${DOCKER_RUN_ARGS:-} \
        -e "BUCKET=test.fake-bucket-for-startup-test" \
        -e "CRON_EXPRESSION=@daily" \
        "${IMAGE}")
    printf '  container %s started; waiting for scheduler init...\n' \
        "${container_id:0:12}" >&2

    sleep 3

    local running
    running=$(docker inspect --format '{{.State.Running}}' "${container_id}" \
        2>/dev/null || echo "false")

    local crontab_ok=false
    if [[ "${running}" == "true" ]]; then
        docker exec "${container_id}" \
            test -f /var/spool/cron/crontabs/rotate-aws-backups \
            > /dev/null 2>&1 && crontab_ok=true
    fi

    docker stop "${container_id}" > /dev/null 2>&1
    docker rm   "${container_id}" > /dev/null 2>&1

    if [[ "${running}" != "true" ]]; then
        echo "FAIL '${FUNCNAME[0]}': container exited within 3s of startup"
        return 1
    fi
    if ! "${crontab_ok}"; then
        echo "FAIL '${FUNCNAME[0]}': crontab file not found" \
             "(crontabs directory likely root-owned)"
        return 1
    fi
    echo "PASS '${FUNCNAME[0]}': scheduler running and crontab written"
}

# ── AWS-dependent tests ───────────────────────────────────────────────────────
# Each test skips when BUCKET/BUCKET_LIST or credentials are absent.

# test_staging_cli_dryrun: run one rotation pass (CLI mode) with DRYRUN=true.
# Verifies the full S3 list → rotate-backups → (dry-run) pipeline end-to-end.
# No objects are deleted.  Expected duration: 10–60 s depending on bucket size.
#
# Root cause of exit=1 when grep finds no matching lines:
#   The rotate-backups pipeline contains:
#     ... | grep -E -i '(Deleting|Ignoring|Preserving)' | ...
#   With 'set -o pipefail', grep exits 1 when no lines match (e.g. an empty
#   bucket, or a rotate-backups build whose output format has changed).  That
#   propagates as the container exit code before the "completed" log line is
#   ever written.  Fixed in src/rotate-aws-backups by wrapping grep in
#   '{ grep ... || true; }' so a "no matches" result is non-fatal.
test_staging_cli_dryrun() {
    _aws_available || { _skip "BUCKET or credentials not configured"; return 0; }

    printf '  starting CLI dry-run rotation (DRYRUN=%s)...\n' \
        "${DRYRUN:-true}" >&2

    local output result=0
    output=$(run_rotate_aws_backups 2>&1) || result=$?

    if [[ ${result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': rotate-aws-backups exited non-zero (${result})"
        printf '  -- full output --\n' >&2
        printf '%s\n' "${output}" >&2
        printf '  -- end output --\n' >&2
        return 1
    fi
    if echo "${output}" | grep -q 'completed.*bucket rotation'; then
        echo "PASS '${FUNCNAME[0]}': CLI rotation completed (DRYRUN=${DRYRUN:-true})"
    else
        echo "FAIL '${FUNCNAME[0]}': 'completed.*bucket rotation' not found in output"
        printf '  -- full output --\n' >&2
        printf '%s\n' "${output}" >&2
        printf '  -- end output --\n' >&2
        return 1
    fi
}

# test_staging_cron_fires: start the full scheduler container and wait for the
# cron daemon to trigger a complete rotation cycle.
# Expected duration: up to 4 m (≤60 s to first cron tick + rotation run time).
test_staging_cron_fires() {
    _aws_available || { _skip "BUCKET or credentials not configured"; return 0; }

    # Schedule every minute so the first fire is at most 60 s away.
    local container_id
    container_id=$(run_service_detached -e "CRON_EXPRESSION=* * * * *")
    printf '  container %s started; waiting for first cron rotation (up to 2m)...\n' \
        "${container_id:0:12}" >&2

    local elapsed=0 timeout=120 interval=10 found=false last_log
    while [[ ${elapsed} -lt ${timeout} ]]; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        if docker logs "${container_id}" 2>&1 | grep -q 'completed.*bucket rotation'; then
            found=true
            break
        fi
        last_log=$(docker logs --tail 1 "${container_id}" 2>&1)
        printf '  [%ds] waiting... (last: %s)\n' "${elapsed}" "${last_log}" >&2
    done

    docker stop "${container_id}" > /dev/null 2>&1
    docker rm   "${container_id}" > /dev/null 2>&1

    if "${found}"; then
        echo "PASS '${FUNCNAME[0]}': cron rotation completed within ${elapsed}s (DRYRUN=${DRYRUN:-true})"
    else
        echo "FAIL '${FUNCNAME[0]}': rotation did not complete within ${timeout}s"
        return 1
    fi
}

# test_staging_rotation_e2e: the only test that validates rotation correctness.
#
# Creates a disposable bucket named test.rotate-aws-backups-<epoch>, populates
# it with 20 synthetic objects — two files per backup event (a .tar.gz and a
# .tar.sha1) — to verify that grouped backup sets are deleted and preserved as
# atomic units.
#
# Object layout (10 backup events × 2 files each = 20 objects total):
#   - 3 recent events: days 1, 2, 3 ago   (inside the 7-day daily window)
#   - 7 old events:    days 60–66 ago      (outside all retention windows)
#
# Retention policy applied: DAILY=7, all other periods=0.
# Expected outcome: exactly 6 objects remain (3 events × 2 files each);
#   all 14 old objects are deleted in matched pairs.
#
# The bucket is always removed in a RETURN trap, even on failure.
# This test always runs DRYRUN=false on its own transient bucket; the caller's
# DRYRUN env var does not apply here.
#
# Required IAM permissions (beyond production): s3:CreateBucket, s3:PutObject,
# s3:DeleteBucket on arn:aws:s3:::test.rotate-aws-backups-*
test_staging_rotation_e2e() {
    _aws_available || { _skip "BUCKET or credentials not configured"; return 0; }

    local epoch test_bucket aws_mounts
    epoch=$(date +%s)
    test_bucket="test.rotate-aws-backups-${epoch}"
    aws_mounts=()
    [[ -r "${_aws_cfg_mount}" ]] && \
        aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
    [[ -r "${_aws_creds_mount}" ]] && \
        aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")

    # Always remove the transient bucket on exit — expand test_bucket now so
    # the variable is captured in the trap string rather than re-evaluated.
    # shellcheck disable=SC2064
    trap "_aws s3 rb 's3://${test_bucket}' --force > /dev/null 2>&1 || true" RETURN

    # ── Create bucket ─────────────────────────────────────────────────────────
    # Use s3api create-bucket with explicit region handling: AWS rejects a
    # LocationConstraint of "us-east-1" — that region requires the constraint
    # to be omitted entirely.  "aws s3 mb" does not handle this reliably across
    # CLI versions when the configured region is us-east-1.
    local _region
    _region=$(_aws configure get region 2>/dev/null) || _region="us-east-1"
    printf '  creating transient test bucket s3://%s (region: %s)...\n' \
        "${test_bucket}" "${_region}" >&2
    local _bucket_out _bucket_result=0
    if [[ "${_region}" == "us-east-1" ]]; then
        _bucket_out=$(_aws s3api create-bucket \
            --bucket "${test_bucket}" 2>&1) || _bucket_result=$?
    else
        _bucket_out=$(_aws s3api create-bucket \
            --bucket "${test_bucket}" \
            --region "${_region}" \
            --create-bucket-configuration "LocationConstraint=${_region}" 2>&1) || _bucket_result=$?
    fi
    if [[ ${_bucket_result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': could not create bucket" \
             "(check s3:CreateBucket on test.rotate-aws-backups-*)"
        printf '  %s\n' "${_bucket_out}" >&2
        return 1
    fi

    # ── Populate ──────────────────────────────────────────────────────────────
    # Two files per backup event (.tar.gz + .tar.sha1) exercise the grouped
    # backup-set behaviour: rotation must delete or preserve both files of each
    # event together, never orphaning one.
    #
    # 3 recent events (days 1–3 ago) fall inside rotate-backups' 7-day daily
    # window.  7 old events (days 60–66 ago) are well outside all retention
    # windows when WEEKLY=0, MONTHLY=0, YEARLY=0.
    # Timestamps at noon UTC avoid DST edge cases near midnight.
    printf '  uploading 20 synthetic backup objects (2 per event)...\n' >&2
    local i ts ext
    for i in 1 2 3 60 61 62 63 64 65 66; do
        ts=$(_days_ago_ts "${i}")
        for ext in tar.gz tar.sha1; do
            _aws s3api put-object \
                --bucket "${test_bucket}" \
                --key "backup-${ts}.${ext}" \
                > /dev/null 2>&1 || {
                echo "FAIL '${FUNCNAME[0]}': could not upload backup-${ts}.${ext}"
                return 1
            }
        done
    done

    # ── Rotate ────────────────────────────────────────────────────────────────
    # Retention is set via env vars (not CLI flags) so CRON_MODE is not
    # triggered.  Only daily retention is active; everything else is 0.
    # DRYRUN=false is unconditional here — the point of this test is live deletion.
    printf '  running live rotation (DAILY=7, no other retention)...\n' >&2
    local rot_output rot_result=0
    local aws_env=()
    [[ -r "${_aws_cfg_mount}" ]] && \
        aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
    [[ -r "${_aws_creds_mount}" ]] && \
        aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
    # shellcheck disable=SC2086
    rot_output=$(docker run --rm ${DOCKER_RUN_ARGS:-} \
        -e "BUCKET=${test_bucket}" \
        -e "DRYRUN=false" \
        -e "HOURLY=0" \
        -e "DAILY=7" \
        -e "WEEKLY=0" \
        -e "MONTHLY=0" \
        -e "YEARLY=0" \
        -e "DELETE_IGNORED=false" \
        "${aws_mounts[@]}" \
        "${aws_env[@]}" \
        "${IMAGE}" 2>&1) || rot_result=$?

    if [[ ${rot_result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': rotation exited non-zero (${rot_result})"
        printf '%s\n' "${rot_output}" | tail -10 >&2
        return 1
    fi

    # ── Verify ────────────────────────────────────────────────────────────────
    # The 3 recent events (6 objects) must remain; all 7 old events (14 objects)
    # must be gone.  A count of anything other than 6 indicates either a missed
    # deletion or a split backup set (one file deleted without its partner).
    local remaining=0
    remaining=$(_aws s3 ls "s3://${test_bucket}/" 2>/dev/null | wc -l | tr -d ' ')

    if [[ "${remaining}" -eq 6 ]]; then
        echo "PASS '${FUNCNAME[0]}': ${remaining}/20 objects remain" \
             "(14 old objects correctly deleted in matched pairs)"
    else
        echo "FAIL '${FUNCNAME[0]}': ${remaining}/20 objects remain (expected 6)"
        printf 'Remaining objects:\n' >&2
        _aws s3 ls "s3://${test_bucket}/" >&2 2>&1 || true
        printf 'Rotation output (last 10 lines):\n' >&2
        printf '%s\n' "${rot_output}" | tail -10 >&2
        return 1
    fi
}

# ── Scan tests ───────────────────────────────────────────────────────
# These inspect the image for known vulnerabilities.  Both are AWS-independent
# and require only Docker and network access to pull the scanner images.

# test_staging_trivy_scan: Trivy HIGH/CRITICAL image scan.
# Mirrors build Stage 4.  Gating: fails when unfixed HIGH/CRITICAL CVEs are
# found.  Skip with --no-scan for fast iteration during development.
test_staging_trivy_scan() {
    [[ "${_SCAN}" == "true" ]] || {
        _skip "--no-scan: Trivy scan skipped"
        return 0
    }
    printf '  running Trivy scan on %s...\n' "${IMAGE}" >&2

    local result=0
    docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
        "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
            --quiet \
            --no-progress \
            --exit-code 1 \
            --ignore-unfixed \
            --severity HIGH,CRITICAL \
            --timeout 5m \
            --input /scan.tar 2>&1 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': no unfixed HIGH/CRITICAL CVEs found"
    else
        echo "FAIL '${FUNCNAME[0]}': unfixed HIGH/CRITICAL CVEs found" \
             "(exit=${result})"
        return 1
    fi
}

# test_staging_grype_advise: Grype full-severity advisory scan.
# Mirrors build Stage 5a.  Non-gating: findings are printed but never cause a
# test failure.  Skipped when --no-advise is set, or when --no-scan is given
# without an explicit --advise.
test_staging_grype_advise() {
    [[ "${_ADVISE_GRYPE}" == "true" ]] || {
        _skip "--no-advise grype: Grype advisory scan skipped"
        return 0
    }
    printf '  running Grype advisory scan on %s...\n' "${IMAGE}" >&2
    local _grype_extra_env=()
    if [[ "${_CACHE_SKIP_UPDATE_GRYPE}" == "true" ]]; then
        echo "    Grype DB update skipped for this run (--cache skip-update=grype)" >&2
        _grype_extra_env+=(-e GRYPE_DB_AUTO_UPDATE=false)
    fi
    docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        -v "${GRYPE_CACHE_VOLUME}:/root/.cache/grype" \
        "${_grype_extra_env[@]}" \
        "${GRYPE_IMAGE}:${GRYPE_TAG}" \
            docker-archive:/scan.tar 2>&1 || true
    echo "PASS '${FUNCNAME[0]}': Grype advisory scan complete (advisory only)"
}

# test_staging_scout_advise: Docker Scout CVE advisory scan.
# Mirrors build Stage 5b.  Non-gating.
test_staging_scout_advise() {
    [[ "${_ADVISE_SCOUT}" == "true" ]] || {
        _skip "--no-advise scout: Docker Scout advisory scan skipped"
        return 0
    }
    printf '  running Docker Scout advisory scan on %s...\n' "${IMAGE}" >&2
    docker scout cves "${IMAGE}" 2>&1 || true
    echo "PASS '${FUNCNAME[0]}': Docker Scout advisory scan complete (advisory only)"
}

# test_staging_dive_advise: Dive image layer analysis.
# Mirrors build Stage 5c.  Non-gating.
test_staging_dive_advise() {
    [[ "${_ADVISE_DIVE}" == "true" ]] || {
        _skip "--no-advise dive: Dive layer analysis skipped"
        return 0
    }
    printf '  running Dive layer analysis on %s...\n' "${IMAGE}" >&2
    docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        "${DIVE_IMAGE}:${DIVE_TAG}" \
            --source docker-archive \
            --ci \
            /scan.tar 2>&1 || true
    echo "PASS '${FUNCNAME[0]}': Dive layer analysis complete (advisory only)"
}

# test_staging_coverage_advise: kcov bash line-coverage report.
# Mirrors build Stage 5d.  Non-gating: results are printed but never cause a
# test failure.  Skipped when --no-coverage or --no-advise is set.
test_staging_coverage_advise() {
    [[ "${_ADVISE_COVERAGE}" == "true" ]] || {
        _skip "--no-coverage: coverage analysis skipped"
        return 0
    }
    local script_dir
    script_dir=$(dirname "$(readlink -f "$0")")
    printf '  running kcov coverage analysis...\n' >&2
    docker run --rm \
        --cap-add SYS_PTRACE \
        --security-opt seccomp=unconfined \
        -v "${script_dir}/..:/code:ro" \
        -w /code \
        "${BATS_KCOV_IMAGE}:${BATS_KCOV_TAG}" \
        bats-coverage \
            test/01-dockerfile.bats \
            test/02-functional.bats \
            test/03-build.bats \
            test/04-image-metadata.bats \
            test/05-common-functions.bats \
            test/06-rotate-aws-backups.bats \
        >&2 || true
    echo "PASS '${FUNCNAME[0]}': coverage analysis complete (advisory only)"
}

# ---------------------------------------------------------------------------
# Test runner
# ---------------------------------------------------------------------------

run_tests() {
    local all_tests=(
        test_staging_help
        test_staging_version
        test_staging_unknown_option
        test_staging_trivy_scan
        test_staging_grype_advise
        test_staging_scout_advise
        test_staging_dive_advise
        test_staging_coverage_advise
        test_staging_no_bucket_cli_mode
        test_staging_cron_no_bucket
        test_staging_cron_startup
        test_staging_cli_dryrun
        test_staging_cron_fires
        test_staging_rotation_e2e
    )

    # Apply --test and --skip-e2e filters.
    local tests=()
    if [[ -n "${_ONLY_TEST}" ]]; then
        # Validate the requested test name before committing.
        local valid=false
        local t
        for t in "${all_tests[@]}"; do
            [[ "${t}" == "${_ONLY_TEST}" ]] && valid=true && break
        done
        if ! "${valid}"; then
            echo "ERROR: unknown test '${_ONLY_TEST}'" >&2
            printf '       Available tests:\n' >&2
            printf '         %s\n' "${all_tests[@]}" >&2
            return 1
        fi
        tests=("${_ONLY_TEST}")
    else
        for t in "${all_tests[@]}"; do
            [[ "${t}" == "test_staging_rotation_e2e" \
                && "${_SKIP_E2E}" == "true" ]] && continue
            tests+=("${t}")
        done
    fi

    setup || { echo "ERROR: Setup failed"; return 1; }

    if [[ "${_CACHE_RESET_TRIVY}" == "true" ]]; then
        echo "==> Cache: reset Trivy DB" >&2
        _reset_cache_db "${TRIVY_CACHE_VOLUME}"
    fi
    if [[ "${_CACHE_RESET_GRYPE}" == "true" ]]; then
        echo "==> Cache: reset Grype DB" >&2
        _reset_cache_db "${GRYPE_CACHE_VOLUME}"
    fi

    echo "Running staging tests for rotate-aws-backups..."
    echo "================================================="
    echo "Image:  ${IMAGE}"
    if _aws_available; then
        echo "Bucket: ${BUCKET:-${BUCKET_LIST:-}}"
        echo "DRYRUN: ${DRYRUN:-true}"
    else
        echo "AWS:    not configured — AWS-dependent tests will be skipped"
    fi
    [[ -n "${_ONLY_TEST}" ]]  && echo "Filter: --test ${_ONLY_TEST}"
    "${_SKIP_E2E}"            && echo "Filter: --skip-e2e"
    echo "Scan:   ${_SCAN} (Trivy HIGH/CRITICAL)"
    echo "Advise: coverage=${_ADVISE_COVERAGE} dive=${_ADVISE_DIVE}" \
         "grype=${_ADVISE_GRYPE} scout=${_ADVISE_SCOUT}"
    echo "================================================="

    _SKIP_COUNT=0
    local passed=0 failed=0
    for t in "${tests[@]}"; do
        if "${t}"; then
            (( ++passed )) || true
        else
            (( ++failed )) || true
        fi
    done
    # Subtract skips from passed: skipped tests exit 0 but are not passes.
    passed=$(( passed - _SKIP_COUNT ))

    local total=$(( ${#tests[@]} ))
    echo "================================================="
    echo "Results: ${passed} passed, ${failed} failed," \
         "${_SKIP_COUNT} skipped (${total} run)"
    return "${failed}"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() {
    # ── Option parsing ────────────────────────────────────────────────────────
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)            IMAGE="$2";                shift ;;
            --bucket)           BUCKET="$2";               shift ;;
            --bucket-list)      BUCKET_LIST="$2";          shift ;;
            --aws-config)       AWS_CONFIG_FILE="$2";      shift ;;
            --aws-credentials)  AWS_CREDENTIALS_FILE="$2"; shift ;;
            --dryrun)       DRYRUN=true  ;;
            --no-dryrun)    DRYRUN=false ;;
            --scan)         _SCAN=true   ;;
            --no-scan)      _SCAN=false  ;;
            --no-coverage)  _ADVISE_COVERAGE=false ;;
            --advise|--advice)
                _ADVISE_EXPLICIT=true
                if [[ $# -gt 1 && "$2" =~ \
                        ^(coverage|dive|grype|scout|all)(,(coverage|dive|grype|scout|all))*$ ]]; then
                    advisements="$2"; shift
                else
                    advisements="grype,scout"
                fi
                _ADVISE_COVERAGE=false
                _ADVISE_DIVE=false
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                IFS=',' read -ra adv_list <<< "$advisements"
                for adv in "${adv_list[@]}"; do
                    case "$adv" in
                        coverage) _ADVISE_COVERAGE=true ;;
                        dive)     _ADVISE_DIVE=true ;;
                        grype)    _ADVISE_GRYPE=true ;;
                        scout)    _ADVISE_SCOUT=true ;;
                        all) _ADVISE_COVERAGE=true; _ADVISE_DIVE=true
                             _ADVISE_GRYPE=true; _ADVISE_SCOUT=true ;;
                        *)   echo "Unknown advisement: $adv" >&2; exit 1 ;;
                    esac
                done
                ;;
            --no-advise)
                _ADVISE_COVERAGE=false
                _ADVISE_DIVE=false
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                _ADVISE_EXPLICIT=true
                ;;
            --cache)
                [[ $# -ge 2 ]] || {
                    echo "option '${1}' requires an argument" >&2; exit 1; }
                _parse_cache_rules "$2"; shift
                ;;
            --yes)          _YES=true    ;;
            --skip-e2e)     _SKIP_E2E=true ;;
            --test)         _ONLY_TEST="$2"; shift ;;
            -h|--help)      show_help; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                echo "Run 'test/staging --help' for usage." >&2
                exit 1 ;;
            *)
                # First non-option positional arg is the image.
                if [[ -z "${IMAGE}" ]]; then
                    IMAGE="$1"
                else
                    echo "Unexpected argument: $1" >&2
                    exit 1
                fi ;;
        esac
        shift
    done

    # --no-scan implies --no-advise unless --advise was given explicitly.
    if [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        _ADVISE_COVERAGE=false
        _ADVISE_DIVE=false
        _ADVISE_GRYPE=false
        _ADVISE_SCOUT=false
    fi

    # Propagate resolved values so setup() and test functions see them.
    export IMAGE BUCKET BUCKET_LIST AWS_CONFIG_FILE AWS_CREDENTIALS_FILE DRYRUN
    export _YES _SKIP_E2E _ONLY_TEST _SCAN
    export _ADVISE_COVERAGE _ADVISE_DIVE _ADVISE_GRYPE _ADVISE_SCOUT
    export _CACHE_RESET_TRIVY _CACHE_RESET_GRYPE
    export _CACHE_SKIP_UPDATE_TRIVY _CACHE_SKIP_UPDATE_GRYPE

    # Derive BUCKET_LIST from BUCKET when not set explicitly.
    [[ -z "${BUCKET_LIST}" && -n "${BUCKET}" ]] && BUCKET_LIST="${BUCKET}"

    # ── Preflight summary ────────────────────────────────────────────────────
    local aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"
    local aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    local bucket="${BUCKET:-${BUCKET_LIST:-}}"

    local will_touch_aws=false
    [[ -n "${bucket}" ]] && \
        { [[ -r "${aws_cfg}" ]] || [[ -r "${aws_creds}" ]] || \
          [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; } && \
        will_touch_aws=true

    echo "================================================================"
    echo " WARNING: test/staging exercises live infrastructure"
    echo "================================================================"
    echo ""
    echo "  Image:    ${IMAGE:-<not set>}"
    if [[ "${_SCAN}" == "true" ]]; then
        echo "  Scan:     Trivy HIGH/CRITICAL (--no-scan to skip)"
    else
        echo "  Scan:     skipped (--no-scan)"
    fi
    local _advise_any=false
    [[ "${_ADVISE_COVERAGE}" == "true" || "${_ADVISE_DIVE}" == "true" \
        || "${_ADVISE_GRYPE}" == "true" || "${_ADVISE_SCOUT}" == "true" ]] \
        && _advise_any=true
    if "${_advise_any}"; then
        local _advise_list=()
        [[ "${_ADVISE_COVERAGE}" == "true" ]] && _advise_list+=(coverage)
        [[ "${_ADVISE_DIVE}"     == "true" ]] && _advise_list+=(dive)
        [[ "${_ADVISE_GRYPE}"    == "true" ]] && _advise_list+=(grype)
        [[ "${_ADVISE_SCOUT}"    == "true" ]] && _advise_list+=(scout)
        local IFS=,
        echo "  Advise:   ${_advise_list[*]} (--no-advise to skip)"
    elif [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        echo "  Advise:   skipped (implied by --no-scan; use --advise to enable)"
    else
        echo "  Advise:   skipped (--no-advise)"
    fi
    echo ""

    # ── Bucket safety check ───────────────────────────────────────────────────
    # For buckets that do not look like test or staging, force DRYRUN=true to
    # prevent accidental production object deletions.  --no-dryrun overrides.
    local caution_bucket=false
    if [[ -n "${bucket}" ]] && \
       [[ "${bucket}" != test.* ]] && \
       [[ "${bucket}" != staging.* ]]; then
        caution_bucket=true
        if [[ "${DRYRUN}" != "false" ]]; then
            DRYRUN=true
            export DRYRUN
        fi
    fi

    if "${will_touch_aws}"; then
        echo "  Bucket:   s3://${bucket}"
        if [[ "${DRYRUN}" == "true" ]]; then
            echo "  Dry-run:  true — no objects will be deleted from this bucket"
        else
            echo "  Dry-run:  false — OBJECTS MAY BE DELETED FROM THIS BUCKET"
        fi
        echo ""
        echo "  E2E test: will CREATE and DELETE a transient bucket:"
        echo "            s3://test.rotate-aws-backups-<epoch>"
        echo "            20 synthetic objects are uploaded, rotated live"
        echo "            (DRYRUN=false), then the bucket is deleted."
        echo "            Requires s3:CreateBucket + s3:PutObject +"
        echo "            s3:DeleteBucket on test.rotate-aws-backups-*"
    else
        echo "  AWS:      not configured — AWS-dependent tests will be skipped"
    fi
    echo ""

    if "${caution_bucket}"; then
        echo "  !! CAUTION !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo "  !! BUCKET='${bucket}'"
        echo "  !! does not start with 'test.' or 'staging.'."
        if [[ "${DRYRUN}" == "true" ]]; then
            echo "  !! DRYRUN forced to 'true'."
            echo "  !! Pass --no-dryrun to allow real object deletions."
        else
            echo "  !! --no-dryrun: objects MAY be deleted from S3."
        fi
        echo "  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo ""
    fi

    # ── Confirmation ──────────────────────────────────────────────────────────
    # Prompt only when real AWS will be touched; --yes skips for scripted use.
    if "${will_touch_aws}"; then
        if "${_YES}"; then
            echo "  (--yes: skipping confirmation prompt)"
            echo ""
        else
            printf 'Type "yes" to proceed, or press Enter to abort: '
            local response
            read -r response
            echo ""
            if [[ "${response}" != "yes" ]]; then
                echo "Aborted."
                return 1
            fi
        fi
    fi

    run_tests
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
