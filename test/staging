_TEST_REQUIRES[test_staging_dive_advise]=''
_ALL_TESTS+=(test_staging_grype_advise)
_TEST_KIND[test_staging_grype_advise]=advise
_TEST_DESTRUCTIVE[test_staging_grype_advise]=false
_TEST_REQUIRES[test_staging_grype_advise]=''
_ALL_TESTS+=(test_staging_scout_advise)
_TEST_KIND[test_staging_scout_advise]=advise
_TEST_DESTRUCTIVE[test_staging_scout_advise]=false
_TEST_REQUIRES[test_staging_scout_advise]=''
_ALL_TESTS+=(test_staging_cli_dryrun)
_TEST_KIND[test_staging_cli_dryrun]=aws
_TEST_DESTRUCTIVE[test_staging_cli_dryrun]=false
_TEST_REQUIRES[test_staging_cli_dryrun]='aws'
_ALL_TESTS+=(test_staging_cron_fires)
_TEST_KIND[test_staging_cron_fires]=aws
_TEST_DESTRUCTIVE[test_staging_cron_fires]=false
_TEST_REQUIRES[test_staging_cron_fires]='aws'
_ALL_TESTS+=(test_staging_rotation_e2e)
_TEST_KIND[test_staging_rotation_e2e]=e2e
_TEST_DESTRUCTIVE[test_staging_rotation_e2e]=true
_TEST_REQUIRES[test_staging_rotation_e2e]='aws'

# ---------------------------------------------------------------------------
# Test runner
# ---------------------------------------------------------------------------
# shellcheck disable=SC2034
# run_tests — iterate over _ALL_TESTS, apply skip rules, call each test
# function, and print a PASS/FAIL/SKIP summary.
# Honors _ONLY_TEST (run a single named test), _SKIP_E2E (skip destructive
# tests), and _meets_requirement (skip tests whose required capability is
# absent).  Sets _SKIP_COUNT for the final summary arithmetic.
# Args: none (reads global test-catalog arrays _ALL_TESTS, _TEST_KIND, etc.)
run_tests() {
    local -a tests=()
    local t t_kind t_destr t_req unmet

    if [[ -n "${_ONLY_TEST}" ]]; then
        local valid=false
        for t in "${_ALL_TESTS[@]}"; do
            [[ "${t}" == "${_ONLY_TEST}" ]] && valid=true && break
        done
        if ! "${valid}"; then
            echo "ERROR: unknown test '${_ONLY_TEST}'" >&2
            printf '       Available tests:\n' >&2
            printf '         %s\n' "${_ALL_TESTS[@]}" >&2
            return 1
        fi
        tests=("${_ONLY_TEST}")
    else
        for t in "${_ALL_TESTS[@]}"; do
            t_destr="${_TEST_DESTRUCTIVE[${t}]:-false}"
            [[ "${t_destr}" == "true" && "${_SKIP_E2E}" == "true" ]] && continue
            tests+=("${t}")
        done
    fi

    setup || { echo "ERROR: setup failed"; return 1; }

    [[ "${_CACHE_RESET_TRIVY}" == "true" ]] && {
        echo "==> Cache: reset Trivy DB" >&2
        _reset_cache_db "${TRIVY_CACHE_VOLUME}"; }
    [[ "${_CACHE_RESET_GRYPE}" == "true" ]] && {
        echo "==> Cache: reset Grype DB" >&2
        _reset_cache_db "${GRYPE_CACHE_VOLUME}"; }

    _SKIP_COUNT=0
    local passed=0 failed=0
    for t in "${tests[@]}"; do
        t_kind="${_TEST_KIND[${t}]:-cli}"
        t_destr="${_TEST_DESTRUCTIVE[${t}]:-false}"
        t_req="${_TEST_REQUIRES[${t}]:-}"

        unmet=false
        if [[ -n "${t_req}" ]]; then
            local _reqs req
            IFS=',' read -ra _reqs <<< "${t_req}"
            for req in "${_reqs[@]}"; do
                if ! _meets_requirement "${req}"; then
                    _skip "${t} (requirement '${req}' not met)"
                    unmet=true; break
                fi
            done
        fi
        "${unmet}" && continue

        if ! declare -F "${t}" > /dev/null 2>&1; then
            echo "ERROR: test function '${t}' not defined" \
                 "(expected in test/staging-hooks.sh)" >&2
            (( ++failed )) || true
            continue
        fi

        if "${t}"; then
            (( ++passed )) || true
        else
            echo "FAIL '${t}'" >&2
            (( ++failed )) || true
        fi
    done

    passed=$(( passed - _SKIP_COUNT ))
    (( passed < 0 )) && passed=0
    # _skip() increments _SKIP_COUNT and prints output, so skipped tests
    # are counted in the running passed total above. Subtract them here so
    # the final tally shows actual passes only.

    local total="${#tests[@]}"
    echo "================================================="
    echo "Results: ${passed} passed, ${failed} failed," \
         "${_SKIP_COUNT} skipped (${total} run)"
    return "${failed}"
}

# _meets_requirement — return 0 if the requirement token is satisfied.
# Used by run_tests to skip tests whose capability is absent at runtime.
# Args: $1=requirement token (aws; all others pass unconditionally)
_meets_requirement() {
    # Maps requirement tokens to availability-check functions.
    # Only 'aws' is meaningful for this profile; all other tokens
    # pass unconditionally.
    case "$1" in
        aws) _aws_available ;;
        *) return 0 ;;
    esac
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)
                [[ -n "${2:-}" ]] || {
                    echo "Option $1 requires a value" >&2; exit 1; }
                IMAGE="$2"; shift ;;
            --bucket)           S3_BUCKET_NAME="$2";        shift ;;
            --bucket-list)      BUCKET_LIST="$2";           shift ;;
            --aws-config)       AWS_CONFIG_FILE="$2";       shift ;;
            --aws-credentials)  AWS_CREDENTIALS_FILE="$2";  shift ;;
            --dryrun)           DRYRUN=true  ;;
            --no-dryrun)        DRYRUN=false ;;
            --scan)             _SCAN=true   ;;
            --no-scan)          _SCAN=false  ;;
            --no-coverage)      _ADVISE_COVERAGE=false ;;
            --advise|--advice)
                _ADVISE_EXPLICIT=true
                if [[ $# -gt 1 && "$2" =~ \
                        ^(coverage|dive|grype|scout|all)(,(coverage|dive|grype|scout|all))*$ ]]; then
                    local _adv_list="$2"; shift
                else
                    local _adv_list="grype,scout"
                fi
                _ADVISE_COVERAGE=false; _ADVISE_DIVE=false
                _ADVISE_GRYPE=false;    _ADVISE_SCOUT=false
                local _adv
                IFS=',' read -ra _advs <<< "${_adv_list}"
                for _adv in "${_advs[@]}"; do
                    case "${_adv}" in
                        coverage) _ADVISE_COVERAGE=true ;;
                        dive)     _ADVISE_DIVE=true ;;
                        grype)    _ADVISE_GRYPE=true ;;
                        scout)    _ADVISE_SCOUT=true ;;
                        all)
                            _ADVISE_COVERAGE=true; _ADVISE_DIVE=true
                            _ADVISE_GRYPE=true;    _ADVISE_SCOUT=true ;;
                        *) echo "Unknown advisement: ${_adv}" >&2; exit 1 ;;
                    esac
                done
                ;;
            --no-advise)
                _ADVISE_COVERAGE=false; _ADVISE_DIVE=false
                _ADVISE_GRYPE=false;    _ADVISE_SCOUT=false
                _ADVISE_EXPLICIT=true
                ;;
            --cache)
                [[ $# -ge 2 ]] || {
                    echo "option '$1' requires an argument" >&2; exit 1; }
                _parse_cache_rules "$2"; shift
                ;;
            --yes)          _YES=true      ;;
            --skip-e2e)     _SKIP_E2E=true ;;
            --test)
                [[ -n "${2:-}" ]] || {
                    echo "Option $1 requires a value" >&2; exit 1; }
                _ONLY_TEST="$2"; shift ;;
            -h|--help)      show_help; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                echo "Run 'test/staging --help' for usage." >&2
                exit 1 ;;
            *)
                if [[ -z "${IMAGE}" ]]; then
                    IMAGE="$1"
                else
                    echo "Unexpected argument: $1" >&2; exit 1
                fi
                ;;
        esac
        shift
    done

    # --no-scan implies --no-advise unless --advise was given explicitly
    if [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        _ADVISE_COVERAGE=false; _ADVISE_DIVE=false
        _ADVISE_GRYPE=false;    _ADVISE_SCOUT=false
    fi

    export IMAGE S3_BUCKET_NAME BUCKET_LIST AWS_CONFIG_FILE AWS_CREDENTIALS_FILE DRYRUN
    export _YES _SKIP_E2E _ONLY_TEST _SCAN
    export _ADVISE_COVERAGE _ADVISE_DIVE _ADVISE_GRYPE _ADVISE_SCOUT _ADVISE_EXPLICIT
    export _CACHE_RESET_TRIVY _CACHE_RESET_GRYPE
    export _CACHE_SKIP_UPDATE_TRIVY _CACHE_SKIP_UPDATE_GRYPE DOCKER_RUN_ARGS

    [[ -z "${BUCKET_LIST}" && -n "${S3_BUCKET_NAME}" ]] && BUCKET_LIST="${S3_BUCKET_NAME}"

    # ── Preflight summary ─────────────────────────────────────────────────────
    local aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"
    local aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    local bucket="${S3_BUCKET_NAME:-${BUCKET_LIST:-}}"
    local will_touch_aws=false
    [[ -n "${bucket}" ]] && \
        { [[ -r "${aws_cfg}" ]] || [[ -r "${aws_creds}" ]] \
          || [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; } && \
        will_touch_aws=true

    echo "================================================================"
    echo " WARNING: test/staging exercises live infrastructure"
    echo "================================================================"
    echo ""
    echo "  Image:    ${IMAGE:-<not set>}"
    if [[ "${_SCAN}" == "true" ]]; then
        echo "  Scan:     Trivy HIGH/CRITICAL (--no-scan to skip)"
    else
        echo "  Scan:     skipped (--no-scan)"
    fi
    local _advise_any=false
    [[ "${_ADVISE_COVERAGE}" == "true" || "${_ADVISE_DIVE}" == "true" \
        || "${_ADVISE_GRYPE}" == "true" || "${_ADVISE_SCOUT}" == "true" ]] \
        && _advise_any=true
    if "${_advise_any}"; then
        local _adv_items=()
        [[ "${_ADVISE_COVERAGE}" == "true" ]] && _adv_items+=(coverage)
        [[ "${_ADVISE_DIVE}"     == "true" ]] && _adv_items+=(dive)
        [[ "${_ADVISE_GRYPE}"    == "true" ]] && _adv_items+=(grype)
        [[ "${_ADVISE_SCOUT}"    == "true" ]] && _adv_items+=(scout)
        local IFS=,
        echo "  Advise:   ${_adv_items[*]} (--no-advise to skip)"
    elif [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        echo "  Advise:   skipped (implied by --no-scan)"
    else
        echo "  Advise:   skipped (--no-advise)"
    fi
    echo ""
    # Bucket safety: force DRYRUN for non-test/staging buckets
    local caution_bucket=false
    if [[ -n "${bucket}" ]] && \
       [[ "${bucket}" != test.* ]] && \
       [[ "${bucket}" != staging.* ]]; then
        caution_bucket=true
        [[ "${DRYRUN}" != "false" ]] && { DRYRUN=true; export DRYRUN; }
    fi

    if "${will_touch_aws}"; then
        echo "  Bucket:   s3://${bucket}"
        if [[ "${DRYRUN}" == "true" ]]; then
            echo "  Dry-run:  true — no objects will be deleted from this bucket"
        else
            echo "  Dry-run:  false — OBJECTS MAY BE DELETED FROM THIS BUCKET"
        fi
        echo ""
    else
        echo "  AWS:      not configured — AWS-dependent tests will be skipped"
        echo ""
    fi

    if "${caution_bucket}"; then
        echo "  !! CAUTION !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo "  !! bucket='${bucket}' does not start with 'test.' or 'staging.'"
        if [[ "${DRYRUN}" == "true" ]]; then
            echo "  !! DRYRUN forced true. Pass --no-dryrun to allow deletions."
        else
            echo "  !! --no-dryrun: objects MAY be deleted from S3."
        fi
        echo "  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo ""
    fi

    # Confirmation prompt
    if "${will_touch_aws}"; then
        if "${_YES}"; then
            echo "  (--yes: skipping confirmation prompt)"
            echo ""
        else
            printf 'Type "yes" to proceed, or press Enter to abort: '
            local response
            read -r response
            echo ""
            [[ "${response}" != "yes" ]] && { echo "Aborted."; return 1; }
        fi
    fi

    run_tests
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
